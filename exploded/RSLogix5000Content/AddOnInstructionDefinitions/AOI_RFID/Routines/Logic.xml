    <Rung Type="N">
      <Comment><![CDATA[Transfer 1 byte data array to 2 byte data array]]></Comment>
      <Text><![CDATA[LBL(distribute2)BTD(node_tempdataok[node_convert_index2],0,node_tempdata[node_convert_index1],8,8)ADD(1,node_convert_index2,node_convert_index2)BTD(node_tempdataok[node_convert_index2],0,node_tempdata[node_convert_index1],0,8)ADD(1,node_convert_index1,node_convert_index1)ADD(1,node_convert_index2,node_convert_index2)JMP(end);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Loop until all arrays are filled]]></Comment>
      <Text><![CDATA[LBL(end)LES(node_convert_index1,node_array_length)[EQU(operation,0) JMP(distribute) ,EQU(operation,1) JMP(distribute2) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(operation,1)EQU(node_convert_index1,node_array_length)CPS(node_tempdata[0],cmd_data_write[6],node_array_length);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(operation,0)[XIC(node_cmd_fill) OTU(node_cmd_fill) OTU(node_cmd_latch) ,XIC(node_cmd_write) OTU(node_cmd_write) OTU(node_cmd_latch) ,XIC(node_cmd_read) OTU(node_cmd_read) OTU(node_cmd_latch) ,XIC(node_cmd_tagid) OTU(node_cmd_tagid) OTU(node_cmd_latch) ,XIC(node_cmd_tag_presence) OTU(node_cmd_tag_presence) OTU(node_cmd_latch) ,XIC(node_cmd_controller_stat) OTU(node_cmd_controller_stat) OTU(node_cmd_latch) ,MUL(2,node_convert_index1,node_convert_index2) CPS(node_tempswap[0],node_tempdataok[0],node_convert_index2) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[MOV(999,operation);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[LBL(data_convert_end)NOP();]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[********        GATEWAY DATA HANDSHAKE        ********
]]></Comment>
      <Text><![CDATA[NOP();]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(node_cmd_latch)ONS(ons_rfid.25)[LES(ctrl_node_read[1],250) ADD(ctrl_node_read[1],1,ctrl_node_read[1]) ,GEQ(ctrl_node_read[1],250) MOV(1,ctrl_node_read[1]) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Complete Handshake]]></Comment>
      <Text><![CDATA[NEQ(ctrl_node_write[1],ctrl_node_read[0])[[XIO(node_cmd_tag_presence) MEQ(ctrl_node_write[3],-256,ctrl_node_read[3]) ,XIC(node_cmd_tag_presence) [EQU(ctrl_node_write[3],ctrl_node_read[3]) BTD(ctrl_node_write[7],0,tag_presence_results,0,8) ,EQU(ctrl_node_write[3],-1) BTD(ctrl_node_write[8],8,tag_presence_results,0,8) ] ] OTL(node_response_ok) ,MEQ(ctrl_node_write[3],-256,-256) OTL(node_response_error) ,MEQ(ctrl_node_write[3],-256,-512) [MVM(ctrl_node_write[3],255,gwy_notification_codes[1]) ,OTL(node_notification) ] ,MOV(ctrl_node_write[1],ctrl_node_read[0]) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Delay to ensure receipt of data before copying and converting data.  ]]></Comment>
      <Text><![CDATA[[XIC(node_response_ok) ONS(ons_rfid.26) OTL(node_write_txfr_delay) ,XIO(node_response_error) XIO(node_write_txfr_delay) ONS(ons_rfid.27) [CPS(ctrl_node_write[8],node_tempdata[0],94) ,MOV(0,operation) JMP(data_convert) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Delay the write copy one scan.
]]></Comment>
      <Text><![CDATA[XIC(node_write_txfr_delay)[TON(node_write_trx_dly_tmr,?,?) ,XIC(node_write_trx_dly_tmr.DN) OTU(node_write_txfr_delay) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Reset Error & Notification Codes and Response latches, if necessary, from the last transaction.   
]]></Comment>
      <Text><![CDATA[XIC(node_cmd_latch)ONS(ons_rfid.28)[CLR(gwy_notification_codes[1]) ,OTU(node_response_ok) OTU(node_no_response) ,OTU(node_response_error) OTU(node_notification) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[protect against a No Response condition (e.g., broken ethernet cable) with a timer.  The timer preset must be longer than the timeout value embedded in the command (RFID_Node1_Read[5]).

]]></Comment>
      <Text><![CDATA[XIC(node_cmd_latch)XIO(step_mode)[CPT(node_no_response_timer.PRE,ctrl_node_read[5]+4000) ,TON(node_no_response_timer,?,?) ,XIC(node_no_response_timer.DN) OTL(node_no_response) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(temp_step_latch)OTU(temp_step_latch);]]></Text>
    </Rung>
  </RLLContent>
</Routine>