      <Text><![CDATA[EQU(sts_seq_step,1020)[[MUL(cycle_count1,188,temp_data_read_start) ,CMP((temp_data_read_start + 188) <= (cfg_tag_total_bytes-1)) MOV(188,temp_data_read_length) ,CMP((temp_data_read_start + 188) > (cfg_tag_total_bytes-1)) CPT(temp_data_read_length,(cfg_tag_total_bytes-1)-(temp_data_read_start)) ] ,MOV(temp_data_read_start,cmd_data_read[4]) MOV(temp_data_read_length,cmd_data_read[5]) ,CPS(cmd_data_read[0],ctrl_node_read[2],100) ,MOV(1030,sts_seq_step) ];]]></Text>
