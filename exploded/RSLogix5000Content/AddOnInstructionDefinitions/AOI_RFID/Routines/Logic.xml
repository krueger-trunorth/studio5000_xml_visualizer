]]></Comment>
      <Text><![CDATA[EQU(sts_seq_step,800)[MOV(0,cmd_data_contr_status[4]) MOV(0,cmd_data_contr_status[5]) MOV(0,controller_status_results) ,FLL(blank[0],node_tempdataok[0],188) OTU(sts_complete) OTL(temp_step_latch) OTU(sts_node_healthy) ,CPS(k_tag_data_blank,sts_read_return,1) CPS(k_blank_string,sts_tagid,1) CPS(k_blank_string_array[0],sts_entire_read_rtn[0],25) ,MOV(810,sts_seq_step) ];]]></Text>
