      <Comment><![CDATA[READ COMPLETE
]]></Comment>
      <Text><![CDATA[EQU(sts_seq_step,1085)[OTU(aoi_data_sort_write_04.data_read_sort_complete) OTU(aoi_data_sort_write_04.data_error) ,AOI_RFID_Data_Sort(aoi_data_sort_write_04,temp_rfid_data_write_sorted,cfg_read,temp_rfid_sint_write_array,4,temp_rfid_sint_read_array,element_list,total_elements,sts_read_return,k_string_characters[2],sts_fault_code,cfg_tag_total_bytes,sts_entire_read_rtn) ,XIO(node_response_error) XIC(aoi_data_sort_write_04.data_read_sort_complete) [OTL(sts_complete) ,MOV(0,sts_seq_step) ] ];]]></Text>
