    </Parameter>
    <Parameter Name="Out" TagType="Base" DataType="LINT" Usage="InOut" Radix="Decimal" Required="true" Visible="true" Constant="false">
      <Description><![CDATA[Output (64-bit LINT) = Input A * Input B]]></Description>
    </Parameter>
  </Parameters>
