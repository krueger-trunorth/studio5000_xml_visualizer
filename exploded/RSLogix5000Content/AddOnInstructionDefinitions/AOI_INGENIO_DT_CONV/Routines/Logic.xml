<?xml version="1.0" encoding="utf-8"?>
<Routine Name="Logic" Type="RLL">
  <RLLContent>
    <Rung Type="N">
      <Text><![CDATA[EQU(date_time_step,0)MOV(10,date_time_step);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(date_time_step,10)[COP(k_empty_string,datetime_converted,1) ,COP(original_datetime,temp_original_datetime,1) ,FIND(temp_original_datetime,k_period_string,1,loc_year_term) [SUB(loc_year_term,1,temp_datetime_year_len) ,MOV(50,date_time_step) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(date_time_step,50)ADD(loc_year_term,1,temp_datetime_month_start)FIND(temp_original_datetime,k_period_string,temp_datetime_month_start,loc_month_term)[SUB(loc_month_term,temp_datetime_month_start,temp_datetime_month_len) ,MOV(100,date_time_step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(date_time_step,100)ADD(loc_month_term,1,temp_datetime_day_start)FIND(temp_original_datetime,k_space_string,temp_datetime_day_start,loc_day_term)[SUB(loc_day_term,temp_datetime_day_start,temp_datetime_day_len) ,MOV(150,date_time_step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(date_time_step,150)ADD(loc_day_term,1,temp_datetime_hour_start)FIND(temp_original_datetime,k_colon_string,temp_datetime_hour_start,loc_hour_term)[SUB(loc_hour_term,temp_datetime_hour_start,temp_datetime_hour_len) ,MOV(200,date_time_step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(date_time_step,200)ADD(loc_hour_term,1,temp_datetime_minute_start)FIND(temp_original_datetime,k_colon_string,temp_datetime_minute_start,loc_minute_term)[SUB(loc_minute_term,temp_datetime_minute_start,temp_datetime_minute_len) ,MOV(250,date_time_step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(date_time_step,250)[MID(temp_original_datetime,temp_datetime_year_len,1,temp_datetime_year) ,MID(temp_original_datetime,temp_datetime_month_len,temp_datetime_month_start,temp_datetime_month) ,MID(temp_original_datetime,temp_datetime_day_len,temp_datetime_day_start,temp_datetime_day) ,MID(temp_original_datetime,temp_datetime_hour_len,temp_datetime_hour_start,temp_datetime_hour) ,MID(temp_original_datetime,temp_datetime_minute_len,temp_datetime_minute_start,temp_datetime_minute) ,MOV(300,date_time_step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(date_time_step,300)[STOD(temp_datetime_month,temp_datetime_month_dint) ,COP(temp_month_3dig_array[temp_datetime_month_dint],temp_datetime_month_3dig,1) ,MOV(350,date_time_step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(date_time_step,350)[CONCAT(datetime_converted,temp_datetime_day,datetime_converted) ,CONCAT(datetime_converted,k_hyphen_string,datetime_converted) ,CONCAT(datetime_converted,temp_datetime_month_3dig,datetime_converted) ,CONCAT(datetime_converted,k_hyphen_string,datetime_converted) ,CONCAT(datetime_converted,temp_datetime_year,datetime_converted) ,CONCAT(datetime_converted,k_space_string,datetime_converted) ,CONCAT(datetime_converted,temp_datetime_hour,datetime_converted) ,CONCAT(datetime_converted,k_colon_string,datetime_converted) ,CONCAT(datetime_converted,temp_datetime_minute,datetime_converted) ,MOV(0,date_time_step) ];]]></Text>
    </Rung>
  </RLLContent>
</Routine>