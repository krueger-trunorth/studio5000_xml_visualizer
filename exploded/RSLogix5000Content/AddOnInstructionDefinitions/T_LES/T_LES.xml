      <DefaultData Format="Decorated">
        <Structure DataType="DateTime">
          <DataValueMember Name="Yr" DataType="DINT" Radix="Decimal" Value="0" />
          <DataValueMember Name="Mo" DataType="DINT" Radix="Decimal" Value="0" />
          <DataValueMember Name="Da" DataType="DINT" Radix="Decimal" Value="0" />
          <DataValueMember Name="Hr" DataType="DINT" Radix="Decimal" Value="0" />
          <DataValueMember Name="Min" DataType="DINT" Radix="Decimal" Value="0" />
          <DataValueMember Name="Sec" DataType="DINT" Radix="Decimal" Value="0" />
          <DataValueMember Name="uSec" DataType="DINT" Radix="Decimal" Value="0" />
        </Structure>
      </DefaultData>
    </LocalTag>
    <LocalTag Name="Wrk_DT2" DataType="DateTime" ExternalAccess="Read/Write">
