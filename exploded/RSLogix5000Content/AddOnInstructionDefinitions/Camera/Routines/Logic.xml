<?xml version="1.0" encoding="utf-8"?>
<Routine Name="Logic" Type="RLL">
  <RLLContent>
    <Rung Type="N">
      <Comment><![CDATA[Timer for Heartbeat Failure
]]></Comment>
      <Text><![CDATA[[MOV(10000,timerHeartbeat.PRE) ,TON(timerHeartbeat,?,?) ,XIC(timerHeartbeat.DN) OTL(bitHeartbeatError) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Reset Alarm and Timer if Heartbeat toggles
]]></Comment>
      <Text><![CDATA[[XIC(vcVisionPro.Responses.bHeartbeat) ONS(onsBits.0) ,XIO(vcVisionPro.Responses.bHeartbeat) ONS(onsBits.1) ][RES(timerHeartbeat) ,OTU(bitHeartbeatError) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Timeout Timer]]></Comment>
      <Text><![CDATA[[NEQ(vcVisionPro.Requests.iRun,0) ,XIC(bitRun_Request) ]XIO(timerRetry.TT)[TON(timerTimeout,?,?) ,XIC(timerTimeout.DN) [OTL(bitError) ,OTU(bitRun_Request) ,OTU(bitSaveLast_Request) ,OTU(bitCalibrate_Request) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[NEQ(vcVisionPro.Requests.iRun,0)[TON(timerRetry,?,?) ,XIC(timerRetry.DN) [CTU(counterRetry,?,?) ,XIO(counterRetry.DN) [ONS(onsBits.5) [CLR(vcVisionPro.Requests.iRun) ,OTL(bitStop_Request) ] ,XIO(bitStop_Request) [OTL(bitRun_Request) ,RES(timerRetry) ] ] ,XIC(counterRetry.DN) [OTL(bitError) ,OTU(bitRun_Request) ,OTU(bitSaveLast_Request) ,OTU(bitCalibrate_Request) ,RES(counterRetry) ] ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Check for Run Continously Request]]></Comment>
      <Text><![CDATA[XIO(bitError)XIC(bitRun_Cont_Request)[ONS(onsBits.3) [MOV(intInspection,vcVisionPro.Requests.iRunContinuous) ,OTU(bitErrorInspection) ] ,EQU(intInspection,vcVisionPro.Responses.iRunContinuous) [OTU(bitRun_Cont_Request) ,CLR(vcVisionPro.Requests.iRunContinuous) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Check for Save Last Request]]></Comment>
      <Text><![CDATA[XIO(bitError)[XIC(bitSaveLast_Request) ,NEQ(0,vcVisionPro.Requests.iSaveLast) EQU(intInspection,vcVisionPro.Requests.iSaveLast) ][ONS(onsBits.4) [MOV(intInspection,vcVisionPro.Requests.iSaveLast) ,OTU(bitComplete) ,OTU(bitErrorInspection) ,OTU(bitSaveLast_Request) ] ,EQU(intInspection,vcVisionPro.Responses.iSaveLast) [OTL(bitComplete) ,CLR(vcVisionPro.Requests.iSaveLast) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Check for update cal request]]></Comment>
      <Text><![CDATA[XIO(bitError)[XIC(bitUpdateCal_Request) ,NEQ(0,vcVisionPro.Requests.iUpdateCalibration) EQU(intInspection,vcVisionPro.Requests.iUpdateCalibration) ][ONS(onsBits.6) [MOV(intInspection,vcVisionPro.Requests.iUpdateCalibration) ,OTU(bitErrorInspection) ,OTU(bitComplete) ,OTU(bitUpdateCal_Request) ] ,EQU(intInspection,vcVisionPro.Responses.iUpdateCalibration) [OTL(bitComplete) ,CLR(vcVisionPro.Requests.iUpdateCalibration) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Check for Run Once Request]]></Comment>
      <Text><![CDATA[XIO(bitError)EQU(0,vcVisionPro.Responses.iRun)EQU(0,vcVisionPro.Responses.iRunComplete)[XIC(bitRun_Request) ,XIC(bitCalibrate_Request) ][MOV(intInspection,vcVisionPro.Requests.iRun) ,XIO(bitCalibrate_Request) OTU(bitCalibrating) ,XIC(bitCalibrate_Request) OTL(bitCalibrating) ,OTU(bitErrorInspection) ,OTU(bitComplete) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Wait for inspection to be started]]></Comment>
      <Text><![CDATA[EQU(intInspection,vcVisionPro.Requests.iRun)EQU(intInspection,vcVisionPro.Responses.iRun)[OTU(bitRun_Request) ,OTU(bitCalibrate_Request) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Wait for inspection to be completed]]></Comment>
      <Text><![CDATA[EQU(intInspection,vcVisionPro.Requests.iRun)EQU(intInspection,vcVisionPro.Responses.iRunComplete)[OTU(bitRun_Request) ,NEQ(vcVisionPro.Results.iResultCode,0) [OTL(bitErrorInspection) ,OTU(bitCalibrating) ] ,EQU(0,vcVisionPro.Results.iResultCode) [XIO(bitCalibrating) OTL(bitComplete) ,XIC(bitCalibrating) MOV(intInspection,vcVisionPro.Requests.iCalibrate) ] ,CLR(vcVisionPro.Requests.iRun) ,RES(counterRetry) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Check for calibration complete]]></Comment>
      <Text><![CDATA[XIO(bitError)XIC(bitCalibrating)EQU(intInspection,vcVisionPro.Responses.iCalibrate)EQU(intInspection,vcVisionPro.Responses.iCalibrate)[OTL(bitComplete) ,CLR(vcVisionPro.Requests.iCalibrate) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Check for Stop Request]]></Comment>
      <Text><![CDATA[XIC(bitStop_Request)[ONS(onsBits.7) [MOV(intInspection,vcVisionPro.Requests.iHalt) ,OTU(bitRun_Request) ,OTU(bitRun_Cont_Request) ,OTU(bitCalibrate_Request) ,OTU(bitUpdateCal_Request) ,MOV(0,VisionStep) ] ,EQU(0,vcVisionPro.Responses.iRun) EQU(0,vcVisionPro.Responses.iRunContinuous) [OTU(bitStop_Request) ,CLR(vcVisionPro.Requests.iHalt) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Wait for values to get sent to VB]]></Comment>
      <Text><![CDATA[XIC(bitReset_Error)[MOV(500,timerReset.PRE) ,TON(timerReset,?,?) ,XIC(timerReset.DN) [CLR(VisionStep) ,OTU(bitError) ,OTU(bitErrorInspection) ,OTU(bitComplete) ,RES(counterRetry) ,OTU(bitReset_Error) ] ,ONS(onsBits.2) [CLR(vcVisionPro.Requests.iCalibrate) ,CLR(vcVisionPro.Requests.iUpdateCalibration) ,CLR(vcVisionPro.Requests.iRun) ,CLR(vcVisionPro.Requests.iRunContinuous) ,CLR(vcVisionPro.Requests.iHalt) ,CLR(vcVisionPro.Requests.iSaveLast) ] ];]]></Text>
    </Rung>
  </RLLContent>
</Routine>