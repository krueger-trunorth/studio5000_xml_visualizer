<?xml version="1.0" encoding="utf-8"?>
<Routine Name="Logic" Type="RLL">
  <RLLContent>
    <Rung Type="N">
      <Comment><![CDATA[Initialization]]></Comment>
      <Text><![CDATA[[MOV(Slack_Timeout,Slack_Timer.PRE) ,MOV(Tension_Timeout,Tension_Timer.PRE) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(Reset)[MOV(0,seqDancer.Step) ,[OTU(Tension_Output) ,OTU(Slack_Output) ] ,OTU(Reset) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Maintenance Functions
Tension output is protected in manual]]></Comment>
      <Text><![CDATA[XIC(Manual_Mode)XIO(seqDancer.Perm)[XIC(Tension_Jog_PB) XIO(Tension_Sensor) [OTL(Tension_Output) ,OTU(Slack_Output) ] ,XIC(Slack_Jog_PB) [OTU(Tension_Output) ,OTL(Slack_Output) ] ,XIO(Slack_Jog_PB) XIO(Tension_Jog_PB) [OTU(Tension_Output) ,OTU(Slack_Output) ] ,XIC(Tension_Sensor) OTU(Tension_Output) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Fault Handling]]></Comment>
      <Text><![CDATA[XIC(Clear_Fault)[OTU(Fault) ,CLR(Fault_Code) ,OTU(Clear_Fault) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Permissive for sequence


]]></Comment>
      <Text><![CDATA[XIC(Run_Permissive)XIO(Fault)XIO(EStop_notOK)OTE(seqDancer.Perm);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Turn off outputs if machine is EStopped
or permissive drops out]]></Comment>
      <Text><![CDATA[[XIC(EStop_notOK) ,XIO(seqDancer.Perm) XIO(Manual_Mode) ][OTU(Tension_Output) ,OTU(Slack_Output) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 0: Determine Web Condition

]]></Comment>
      <Text><![CDATA[EQU(seqDancer.Step,0)XIC(seqDancer.Perm)[XIO(Slack_Sensor) XIO(Tension_Sensor) XIC(Middle_Sensor) MOV(10,seqDancer.Step) ,XIC(Tension_Sensor) XIO(Middle_Sensor) MOV(50,seqDancer.Step) ,XIO(Middle_Sensor) XIO(Slack_Sensor) XIO(Tension_Sensor) MOV(200,seqDancer.Step) ,XIC(Slack_Sensor) XIO(Middle_Sensor) MOV(100,seqDancer.Step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 10: Shut off outputs, web position is okay 

]]></Comment>
      <Text><![CDATA[EQU(seqDancer.Step,10)XIC(seqDancer.Perm)[OTU(Tension_Output) ,OTU(Slack_Output) ,MOV(0,seqDancer.Step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 50:  Too much tension, must release slack

]]></Comment>
      <Text><![CDATA[EQU(seqDancer.Step,50)XIC(seqDancer.Perm)[OTU(Tension_Output) ,OTL(Slack_Output) ,MOV(60,seqDancer.Step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 60:  Wait for Tension Sensor to go off

]]></Comment>
      <Text><![CDATA[EQU(seqDancer.Step,60)XIC(seqDancer.Perm)[TON(Tension_Timer,?,?) ,XIO(Tension_Sensor) XIC(Middle_Sensor) MOV(0,seqDancer.Step) ,XIC(Tension_Sensor) XIC(Tension_Timer.DN) [MOV(0,seqDancer.Step) ,OTU(Slack_Output) ,OTU(Tension_Output) ,OTL(Fault) ,MOV(1,Fault_Code) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 100:  Too much slack, must take in web

]]></Comment>
      <Text><![CDATA[EQU(seqDancer.Step,100)XIC(seqDancer.Perm)[OTL(Tension_Output) ,OTU(Slack_Output) ,MOV(110,seqDancer.Step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 110:  Wait for slack sensor to go off

]]></Comment>
      <Text><![CDATA[EQU(seqDancer.Step,110)XIC(seqDancer.Perm)[TON(Slack_Timer,?,?) ,XIO(Slack_Sensor) XIC(Middle_Sensor) MOV(0,seqDancer.Step) ,XIC(Slack_Sensor) XIC(Slack_Timer.DN) [MOV(0,seqDancer.Step) ,OTU(Slack_Output) ,OTU(Tension_Output) ,OTL(Fault) ,MOV(2,Fault_Code) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 200:  No sensors were on, find where I am at

]]></Comment>
      <Text><![CDATA[EQU(seqDancer.Step,200)XIC(seqDancer.Perm)[XIO(DefaultAddSlack) [OTU(Slack_Output) ,OTL(Tension_Output) ] ,XIC(DefaultAddSlack) [OTL(Slack_Output) ,OTU(Tension_Output) ] ,[XIC(Middle_Sensor) ,XIC(Slack_Sensor) ,XIC(Tension_Sensor) ] MOV(0,seqDancer.Step) ];]]></Text>
    </Rung>
  </RLLContent>
</Routine>