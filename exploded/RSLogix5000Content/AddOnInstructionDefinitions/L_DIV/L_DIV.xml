<?xml version="1.0" encoding="utf-8"?>
<AddOnInstructionDefinition Name="L_DIV" Revision="1.0" RevisionExtension="00 Release" Vendor="Rockwell Automation" ExecutePrescan="false" ExecutePostscan="false" ExecuteEnableInFalse="false" CreatedDate="2009-06-19T16:40:26.214Z" CreatedBy="Not Available" EditedDate="2009-07-31T14:34:30.970Z" EditedBy="Not Available" SoftwareRevision="v16.03">
  <Description><![CDATA[Divide (64-bit by 32-bit)]]></Description>
  <RevisionNote><![CDATA[Initial Release]]></RevisionNote>
  <AdditionalHelpText><![CDATA[This instruction implements an elementary-school shift/subtract (looping)
method of dividing a 64-bit integer (LINT) dividend by a 32-bit integer (DINT)
divisor.  The resulting quotient is a 64-bit integer (LINT), and the remainder
(32-bit integer DINT) is also returned.]]></AdditionalHelpText>
  <Parameters>
    <Parameter Name="EnableIn" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
      <Description><![CDATA[Enable Input - System Defined Parameter]]></Description>
    </Parameter>
    <Parameter Name="EnableOut" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
      <Description><![CDATA[Enable Output - System Defined Parameter]]></Description>
    </Parameter>
    <Parameter Name="Inp_Dividend" TagType="Base" DataType="LINT" Usage="InOut" Radix="Decimal" Required="true" Visible="true" Constant="false">
      <Description><![CDATA[Dividend (numerator) 64-bit]]></Description>
    </Parameter>
    <Parameter Name="Inp_Divisor" TagType="Base" DataType="DINT" Usage="InOut" Radix="Decimal" Required="true" Visible="true" Constant="false">
      <Description><![CDATA[Divisor (denominator) 32-bit]]></Description>
    </Parameter>
    <Parameter Name="Out_Quotient" TagType="Base" DataType="LINT" Usage="InOut" Radix="Decimal" Required="true" Visible="true" Constant="false">
      <Description><![CDATA[Quotient (result) 64-bit]]></Description>
    </Parameter>
    <Parameter Name="Out_Remainder" TagType="Base" DataType="DINT" Usage="InOut" Radix="Decimal" Required="true" Visible="true" Constant="false">
      <Description><![CDATA[Remainder 32-bit]]></Description>
    </Parameter>
  </Parameters>
