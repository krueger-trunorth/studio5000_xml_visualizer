<?xml version="1.0" encoding="utf-8"?>
<Routine Name="seqManual_Hitch" Type="RLL">
  <Description><![CDATA[Manual Hitching]]></Description>
  <RLLContent>
    <Rung Type="N">
      <Comment><![CDATA[Manual Hitch Sequence]]></Comment>
      <Text><![CDATA[NOP();]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(seqManualHitch.Reset)[CLR(seqManualHitch.Step) ,OTU(seqManualHitch.On) ,OTU(seqManualHitch.Fault) ,CLR(seqManualHitch.Fault_Code) ,OTU(seqManualHitch.Reset) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Permissive for Sequence

]]></Comment>
      <Text><![CDATA[XIC(System.Manual)XIO(System.Auto)XIO(I_Estop_NOT_OK)XIO(Dancer_Payout.Fault)XIO(Dancer_Takeup.Fault)XIO(seqManualHitch.Fault)XIC(seqManualHitch.On)XIO(seqManualPunch.On)OTE(seqManualHitch.Perm);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(seqManualHitch.On)XIC(seqWebDancer.Fault)XIO(Dancer_Payout.Fault)XIO(Dancer_Takeup.Fault)OTU(seqWebDancer.Fault);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[[XIC(I_Estop_NOT_OK) ,XIC(seqManualHitch.Fault) ,XIO(System.Manual) ]OTU(seqManualHitch.On);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 0:
Retract Die Punch]]></Comment>
      <Text><![CDATA[EQU(seqManualHitch.Step,0)XIC(seqManualHitch.Perm)CONCAT(Message_ManHitch[0],K_Str_Blank,seqManualHitch.Status)[OTL(actDiePunch.ACT.Retract_Req) ,XIC(actDiePunch.ACT.Fault) OTL(seqManualHitch.Fault) ,XIC(actDiePunch.ACT.Retract_Complete) MOV(2,seqManualHitch.Step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 2:
Close Fixed Grippers]]></Comment>
      <Text><![CDATA[EQU(seqManualHitch.Step,2)XIC(seqManualHitch.Perm)CONCAT(Message_ManHitch[2],K_Str_Blank,seqManualHitch.Status)[OTL(actFixedHitchPreDie.ACT.Extend_Req) ,OTL(actFixedHitchPostDie.ACT.Extend_Req) ,[XIC(actFixedHitchPreDie.ACT.Fault) ,XIC(actFixedHitchPostDie.ACT.Fault) ] OTL(seqManualHitch.Fault) ,XIC(actFixedHitchPreDie.ACT.Extend_Complete) XIC(actFixedHitchPostDie.ACT.Extend_Complete) MOV(5,seqManualHitch.Step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 5:
Open Moving Grippers]]></Comment>
      <Text><![CDATA[EQU(seqManualHitch.Step,5)XIC(seqManualHitch.Perm)CONCAT(Message_ManHitch[3],K_Str_Blank,seqManualHitch.Status)[OTL(actMovingHitch.ACT.Retract_Req) ,XIC(actMovingHitch.ACT.Fault) OTL(seqManualHitch.Fault) ,XIC(actMovingHitch.ACT.Retract_Complete) MOV(10,seqManualHitch.Step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 10:
Retract Indexer]]></Comment>
      <Text><![CDATA[EQU(seqManualHitch.Step,10)XIC(seqManualHitch.Perm)CONCAT(Message_ManHitch[4],K_Str_Blank,seqManualHitch.Status)[OTL(actIndexer.ACT.Retract_Req) ,XIC(actIndexer.ACT.Fault) OTL(seqManualHitch.Fault) ,XIC(actIndexer.ACT.Retract_Complete) MOV(20,seqManualHitch.Step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 20:
Close Moving Grippers]]></Comment>
      <Text><![CDATA[EQU(seqManualHitch.Step,20)XIC(seqManualHitch.Perm)CONCAT(Message_ManHitch[5],K_Str_Blank,seqManualHitch.Status)[OTL(actMovingHitch.ACT.Extend_Req) ,XIC(actMovingHitch.ACT.Fault) OTL(seqManualHitch.Fault) ,XIC(actMovingHitch.ACT.Extend_Complete) MOV(30,seqManualHitch.Step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 30:
Open Fixed Hitch Grippers]]></Comment>
      <Text><![CDATA[EQU(seqManualHitch.Step,30)XIC(seqManualHitch.Perm)CONCAT(Message_ManHitch[6],K_Str_Blank,seqManualHitch.Status)[OTL(actFixedHitchPostDie.ACT.Retract_Req) OTL(actFixedHitchPreDie.ACT.Retract_Req) ,[XIC(actFixedHitchPostDie.ACT.Fault) ,XIC(actFixedHitchPreDie.ACT.Fault) ] OTL(seqManualHitch.Fault) ,XIC(actFixedHitchPostDie.ACT.Retract_Complete) XIC(actFixedHitchPreDie.ACT.Retract_Complete) MOV(40,seqManualHitch.Step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 40:
Wait for dancers to home]]></Comment>
      <Text><![CDATA[EQU(seqManualHitch.Step,40)XIC(seqManualHitch.Perm)CONCAT(Message_ManHitch[7],K_Str_Blank,seqManualHitch.Status)XIC(I_Payout_Home)XIC(I_Takeup_Home)MOV(50,seqManualHitch.Step);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 50:
Extend Indexer]]></Comment>
      <Text><![CDATA[EQU(seqManualHitch.Step,50)XIC(seqManualHitch.Perm)CONCAT(Message_ManHitch[8],K_Str_Blank,seqManualHitch.Status)[OTL(actIndexer.ACT.Extend_Req) ,XIC(actIndexer.ACT.Fault) OTL(seqManualHitch.Fault) ,XIC(actIndexer.ACT.Extend_Complete) [MOV(60,seqManualHitch.Step) ,CTU(Machine_Counters[9],?,?) ,SUB(HMI.To_HMI.Manual_Hitch_Number,1,HMI.To_HMI.Manual_Hitch_Number) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 60:
Close Fixed Grippers]]></Comment>
      <Text><![CDATA[EQU(seqManualHitch.Step,60)XIC(seqManualHitch.Perm)CONCAT(Message_ManHitch[9],K_Str_Blank,seqManualHitch.Status)[OTL(actFixedHitchPreDie.ACT.Extend_Req) OTL(actFixedHitchPostDie.ACT.Extend_Req) ,[XIC(actFixedHitchPreDie.ACT.Fault) ,XIC(actFixedHitchPostDie.ACT.Fault) ] OTL(seqManualHitch.Fault) ,XIC(actFixedHitchPreDie.ACT.Extend_Complete) XIC(actFixedHitchPostDie.ACT.Extend_Complete) MOV(80,seqManualHitch.Step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 80:
Open Moving Grippers]]></Comment>
      <Text><![CDATA[EQU(seqManualHitch.Step,80)XIC(seqManualHitch.Perm)CONCAT(Message_ManHitch[10],K_Str_Blank,seqManualHitch.Status)[OTL(actMovingHitch.ACT.Retract_Req) ,XIC(actMovingHitch.ACT.Fault) OTL(seqManualHitch.Fault) ,XIC(actMovingHitch.ACT.Retract_Complete) MOV(90,seqManualHitch.Step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 90: Determine if done]]></Comment>
      <Text><![CDATA[EQU(seqManualHitch.Step,90)XIC(seqManualHitch.Perm)[XIO(Machine_Counters[9].DN) MOV(10,seqManualHitch.Step) ,XIC(Machine_Counters[9].DN) MOV(100,seqManualHitch.Step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 100:
Retract Indexer
and
Wait for Dancers to Home]]></Comment>
      <Text><![CDATA[EQU(seqManualHitch.Step,100)XIC(seqManualHitch.Perm)CONCAT(Message_ManHitch[11],K_Str_Blank,seqManualHitch.Status)[OTL(actIndexer.ACT.Retract_Req) ,XIC(actIndexer.ACT.Fault) OTL(seqManualHitch.Fault) ,XIC(actIndexer.ACT.Retract_Complete) XIC(I_Payout_Home) XIC(I_Takeup_Home) [OTU(seqManualHitch.On) ,OTL(seqManualHitch.Complete) ] ];]]></Text>
    </Rung>
  </RLLContent>
</Routine>