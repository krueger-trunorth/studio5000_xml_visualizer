<?xml version="1.0" encoding="utf-8"?>
<Routine Name="seqRobot_Discrete" Type="RLL">
  <Description><![CDATA[step 300 = discrete]]></Description>
  <RLLContent>
    <Rung Type="N">
      <Comment><![CDATA[Step 300:
Beginning of Discrete Component 
Vacuum Check on EOAT, request discrete if ok]]></Comment>
      <Text><![CDATA[EQU(seqRobot.Step,300)XIC(seqRobot.Perm)CONCAT(Message_Robot[32],K_Str_Blank,seqRobot.Status)[XIC(System.Auto) XIO(Bit_RobotOnlyStepMode) ,XIC(seqRobot.StepNext) ][OTL(actRobotVac.ACT.Extend_Req) ,[XIC(actRobotVac.ACT.Extend_Complete) ,XIC(Speed_Up_Cycle_Time) ] [XIC(I_EOAT_Vac) [MOV(800,seqRobot.Step) ,OTU(Bit_PMDiscreteStartup_Req) ,OTL(Bit_Robot_Part_Stuck_Trigger) ,OTL(seqRobot.Fault) ,OTU(seqRobot.StepNext) ] ,XIO(I_EOAT_Vac) [MOV(302,seqRobot.Step) ,OTL(Sig_Discrete_NeededBy_Robot) ,OTU(seqRobot.StepNext) ,OTL(actRobotVac.ACT.Abort) ] ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 302: Move to Waypoint

JEO - Updated to move into die right away rather than go to approach position since robot is never waiting for die to punch. - 11/10/14]]></Comment>
      <Text><![CDATA[EQU(seqRobot.Step,302)XIC(seqRobot.Perm)CONCAT(Message_Robot[33],K_Str_Blank,seqRobot.Status)[XIC(System.Auto) XIO(Bit_RobotOnlyStepMode) ,XIC(seqRobot.StepNext) ][ONS(Machine_Oneshots[5].26) [MOV(s800.Robot.MotionCounter,intMotionCounter) ,COP(s800.LocationConfig[Loc_Abort_Waypoint],s800.LocationConfig[iLocTemp],1) ,MOV(iLocTemp,s800.Commands.MoveLocationIndex) ,OTL(s800.Commands.Jump_Req) ] ,XIC(s800.Robot.statFaulted) OTL(seqRobot.Fault) ,XIO(s800.Commands.Jump_Req) NEQ(s800.Robot.MotionCounter,intMotionCounter) XIC(s800.Robot.Jump_Complete) [MOV(310,seqRobot.Step) ,OTU(seqRobot.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 310:
Wait for discrete punch, then move to pick.

JEO - Updated to a jump request from a move request since we are now going straight into the die. - 11/10/14]]></Comment>
      <Text><![CDATA[EQU(seqRobot.Step,310)XIC(seqRobot.Perm)CONCAT(Message_Robot[34],K_Str_Blank,seqRobot.Status)[XIC(System.Auto) XIO(Bit_RobotOnlyStepMode) ,XIC(seqRobot.StepNext) ]XIO(Sig_Discrete_NeededBy_Robot)[ONS(Machine_Oneshots[4].15) [MOV(s800.Robot.MotionCounter,intMotionCounter) ,COP(s800.LocationConfig[Loc_Die_Touch],s800.LocationConfig[iLocTemp],1) ,MOV(iLocTemp,s800.Commands.MoveLocationIndex) ,OTL(s800.Commands.Jump_Req) ] ,XIC(s800.Robot.statFaulted) OTL(seqRobot.Fault) ,XIO(s800.Commands.Jump_Req) NEQ(s800.Robot.MotionCounter,intMotionCounter) XIC(s800.Robot.Jump_Complete) [MOV(315,seqRobot.Step) ,OTU(seqRobot.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 315:
Wait for die to transfer part, then crank on robot vacuum]]></Comment>
      <Text><![CDATA[EQU(seqRobot.Step,315)XIC(seqRobot.Perm)CONCAT(Message_Robot[35],K_Str_Blank,seqRobot.Status)[XIC(System.Auto) XIO(Bit_RobotOnlyStepMode) ,XIC(seqRobot.StepNext) ][OTL(actRobotVac.ACT.Extend_Req) ,XIC(actRobotVac.ACT.Extend_Complete) [MOV(320,seqRobot.Step) ,OTU(seqRobot.StepNext) ,OTL(Sig_Robot_AtPunch) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 320:
Move to die approach location]]></Comment>
      <Text><![CDATA[EQU(seqRobot.Step,320)XIC(seqRobot.Perm)CONCAT(Message_Robot[36],K_Str_Blank,seqRobot.Status)[XIC(System.Auto) XIO(Bit_RobotOnlyStepMode) ,XIC(seqRobot.StepNext) ]XIO(Sig_Robot_AtPunch)[ONS(Machine_Oneshots[4].16) [MOV(s800.Robot.MotionCounter,intMotionCounter) ,COP(s800.LocationConfig[Loc_Die_Punch],s800.LocationConfig[iLocTemp],1) ,MOV(iLocTemp,s800.Commands.MoveLocationIndex) ,OTL(s800.Commands.Jump_Req) ] ,XIC(s800.Robot.statFaulted) OTL(seqRobot.Fault) ,XIO(s800.Commands.Jump_Req) NEQ(s800.Robot.MotionCounter,intMotionCounter) XIC(s800.Robot.Jump_Complete) [MOV(325,seqRobot.Step) ,OTU(seqRobot.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 325:
Vac check that discrete was picked
if not loop back up to start]]></Comment>
      <Text><![CDATA[EQU(seqRobot.Step,325)XIC(seqRobot.Perm)CONCAT(Message_Robot[37],K_Str_Blank,seqRobot.Status)[XIC(System.Auto) XIO(Bit_RobotOnlyStepMode) ,XIC(seqRobot.StepNext) ][OTL(Sig_Robot_Departed_fromPunch) ,XIC(I_EOAT_Vac) [MOV(332,seqRobot.Step) ,CPS(StackData.HMI_Discrete_Data_Queue,Discrete_Just_Picked,1) ,OTL(Sig_RobotPickedDiscrete) ,OTU(seqRobot.StepNext) ] ,XIO(I_EOAT_Vac) [MOV(310,seqRobot.Step) ,OTU(Sig_RobotPickedDiscrete) ,OTL(Sig_Discrete_NeededBy_Robot) ,OTL(Bit_Robot_Part_Missing_Trigger) ,OTL(_debug.7) ,OTL(seqRobot.Fault) ,OTU(seqRobot.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 330:
jump to stack discrete]]></Comment>
      <Text><![CDATA[EQU(seqRobot.Step,330)XIC(seqRobot.Perm)[XIC(System.Auto) XIO(Bit_RobotOnlyStepMode) ,XIC(seqRobot.StepNext) ][MOV(200,seqRobot.Step) ,OTU(seqRobot.StepNext) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 332: Move to Waypoint]]></Comment>
      <Text><![CDATA[EQU(seqRobot.Step,332)XIC(seqRobot.Perm)CONCAT(Message_Robot[39],K_Str_Blank,seqRobot.Status)[XIC(System.Auto) XIO(Bit_RobotOnlyStepMode) ,XIC(seqRobot.StepNext) ][ONS(Machine_Oneshots[6].19) [MOV(s800.Robot.MotionCounter,intMotionCounter) ,COP(s800.LocationConfig[Loc_Abort_Waypoint],s800.LocationConfig[iLocTemp],1) ,MOV(iLocTemp,s800.Commands.MoveLocationIndex) ,OTL(s800.Commands.Jump_Req) ] ,XIC(s800.Robot.statFaulted) OTL(seqRobot.Fault) ,XIO(s800.Commands.Jump_Req) NEQ(s800.Robot.MotionCounter,intMotionCounter) XIC(s800.Robot.Jump_Complete) [MOV(330,seqRobot.Step) ,OTU(seqRobot.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[[XIO(I_PM_Drawer_Closed) ,XIO(I_PM_Drawer_Locked) ]OTU(Bit_Discrete_RFID_AlreadyRead);]]></Text>
    </Rung>
  </RLLContent>
</Routine>