<?xml version="1.0" encoding="utf-8"?>
<Routine Name="rtControl" Type="RLL">
  <Description><![CDATA[Function Control]]></Description>
  <RLLContent>
    <Rung Type="N">
      <Comment><![CDATA[This routine is responsible for control portions of the machine and also user interface buttons]]></Comment>
      <Text><![CDATA[NOP();]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[This rung prevents mylar from being stretched out if machine is unused for a long period of time]]></Comment>
      <Text><![CDATA[XIO(System.Running)XIO(seqManualPunch.On)XIC(I_Stack_Pressure_OK)[TON(Machine_Timers[14],?,?) ,XIC(Machine_Timers[14].DN) OTL(actStackPressure.ACT.Retract_Req) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Door Permissive Computation below
Add Doors as appropriate

]]></Comment>
      <Text><![CDATA[[XIO(I_Estop_NOT_OK) [XIO(I_FrontLeftDoor_Open) XIO(I_FrontRightDoor_Open) XIO(I_RightLeftDoor_Open) XIO(I_RightRightDoor_Open) XIO(I_RearLeftDoor_Open) XIO(I_RearRightDoor_Open) XIO(I_LeftLeftDoor_Open) XIO(I_LeftRightDoor_Open) ,XIC(I_Interlocks_Bypassed) ] TON(Machine_Timers[0],?,?) ,XIC(Machine_Timers[0].DN) [OTE(Permissive_Interlocks_OK) ,OTE(Permissive_Motion_OK) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Locking of doors
add doors as appropriate

]]></Comment>
      <Text><![CDATA[XIC(System.Auto)XIO(I_Estop_NOT_OK)XIO(I_FrontLeftDoor_Open)XIO(I_FrontRightDoor_Open)XIO(I_RightLeftDoor_Open)XIO(I_RightRightDoor_Open)XIO(I_RearLeftDoor_Open)XIO(I_RearRightDoor_Open)XIO(I_LeftLeftDoor_Open)XIO(I_LeftRightDoor_Open)[XIC(seqControl.On) ,XIC(seqAbort.On) ,XIC(seqHoming.On) ]XIO(bitSeqDoorUnlock)XIO(System.Paused)XIO(I_Interlocks_Bypassed)OTE(O_Lock_Door);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[[EQU(seqAbort.Step,250) ,EQU(seqCal_Camera.Step,55) ,EQU(seqCal_Camera.Step,5) ,EQU(seqVer_Camera.Step,5) ]OTE(bitSeqDoorUnlock);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Pneumatics Permissive computation below]]></Comment>
      <Text><![CDATA[XIC(Permissive_Interlocks_OK)XIO(Alarms[0].1)OTE(Permissive_Pneumatics_OK);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Vacuum Permissive computation below]]></Comment>
      <Text><![CDATA[XIO(Alarms[0].3)OTE(Permissive_Vacuum_OK);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Main Control Faulting 

]]></Comment>
      <Text><![CDATA[XIC(System.Running)[XIO(Permissive_Interlocks_OK) ,XIO(Permissive_Motion_OK) ,XIO(Permissive_Pneumatics_OK) ,XIO(Permissive_Vacuum_OK) ]OTL(seqControl.Fault);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[System in auto mode

Bit Pause IP is in place to finish critical steps]]></Comment>
      <Text><![CDATA[[XIO(System.Manual) ,XIC(System.Pause_IP) ]XIO(System.Stepping)OTE(System.Auto);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(System.Auto)XIC(bitAbortAfterManSeq)ONS(ONS_Abort_After_Man_Seq)OTL(seqAbort.On);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Single Step Functionality
add each sequence you plan to SS below]]></Comment>
      <Text><![CDATA[NOP();]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(HMI.From_HMI.Home_SS_PB)[XIC(seqHoming.Perm) OTL(seqHoming.StepNext) ,OTU(HMI.From_HMI.Home_SS_PB) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(HMI.From_HMI.Abort_SS_PB)[XIC(seqAbort.Perm) OTL(seqAbort.StepNext) ,OTU(HMI.From_HMI.Abort_SS_PB) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(HMI.From_HMI.SS_Robot)[XIC(seqRobot.Perm) OTL(seqRobot.StepNext) ,OTU(HMI.From_HMI.SS_Robot) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(HMI.From_HMI.SS_HitchPunch)[XIC(seqHitchPunch.Perm) OTL(seqHitchPunch.StepNext) ,OTU(HMI.From_HMI.SS_HitchPunch) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(HMI.From_HMI.SS_CanInsert)[XIC(seqCanInsert.Perm) OTL(seqCanInsert.StepNext) ,OTU(HMI.From_HMI.SS_CanInsert) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(HMI.From_HMI.SS_TransferGripper)[XIC(seqCanInsert.Perm) OTL(seqTransferGripper.StepNext) ,OTU(HMI.From_HMI.SS_TransferGripper) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(HMI.From_HMI.SS_ClearConveyor)[XIC(SeqClearConveyor.Perm) OTL(SeqClearConveyor.StepNext) ,OTU(HMI.From_HMI.SS_ClearConveyor) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Operator interface buttons area

]]></Comment>
      <Text><![CDATA[NOP();]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[GEQ(System.Access_Level,1)XIO(System.Manual)XIO(seqControl.On)XIC(bitAllLocationsLoaded)OTE(HMI.To_HMI.HomeEnable);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Home button is pressed from HMI]]></Comment>
      <Text><![CDATA[XIC(HMI.From_HMI.Home_PB)[XIO(seqHoming.On) NEQ(seqHoming.Step,0) OTL(seqHoming.Reset) ,GEQ(System.Access_Level,1) [XIC(System.Auto) ,XIC(System.Stepping) ] ONS(Machine_Oneshots[0].8) [OTL(seqHoming.On) ,OTU(seqHoming.Complete) ,OTU(seqControl.On) ] ,OTU(HMI.From_HMI.Home_PB) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Start Button Visibility (Forces User to download recipe if no active recipe)
Tray Locations are updated on recipe download - Can only update tray locations when not running robot seq
Start button is visible after system is homed, camera cal ok needed for Idle mode, recipe is loaded and Idle

JEO - Updated to remove requirement to have recipe loaded since recipe is automatically loaded.  - 05/15/15]]></Comment>
      <Text><![CDATA[XIC(System.Homed)EQU(System.Status,10)OTE(HMI.To_HMI.Start_PB_Visibility);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(HMI.To_HMI.ActiveRecipe.LEN,0)OTU(HMI.From_HMI.RecipeDownloaded);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Start button is pressed from HMI
Note that the recipe is copied to the machine run recipe from the queue]]></Comment>
      <Text><![CDATA[XIC(HMI.From_HMI.Start_PB)[XIO(seqVer_Camera.On) XIO(seqOpHitch.On) GEQ(System.Access_Level,1) ONS(Machine_Oneshots[0].5) XIC(Permissive_Motion_OK) XIC(Permissive_Interlocks_OK) XIC(System.Homed) XIC(seqAbort.Complete) [XIC(seqControl.Complete) [OTL(bitLoadSettings) ,OTU(bitLoadRecipeComplete) OTU(bitLoadSettingsComplete) ,OTL(Bit_Start_Program_Sequences) ] ,XIC(System.Stopping) OTU(System.Stopping) ] ,OTU(HMI.From_HMI.Start_PB) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Calibrate Camera]]></Comment>
      <Text><![CDATA[[GEQ(System.Access_Level,2) XIC(System.Homed) XIC(seqAbort.Complete) XIO(seqControl.On) OTE(bitCameraCalEnable) ,XIC(HMI.From_HMI.Calibrate_Camera) [XIC(bitCameraCalEnable) [OTL(seqCal_Camera.On) ,OTL(seqControl.On) ,OTU(System.Stopping) ] ,OTU(HMI.From_HMI.Calibrate_Camera) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Clear Conveyor]]></Comment>
      <Text><![CDATA[[GEQ(System.Access_Level,1) XIC(System.Homed) XIC(seqAbort.Complete) XIO(seqControl.On) OTE(bitClearConveyorEnable1) ,XIC(HMI.From_HMI.ClearConveyor_PB) [XIC(bitClearConveyorEnable1) [OTL(SeqClearConveyor.On) ,OTL(seqConveyor_Anode.On) ,OTL(seqConveyor_Cathode.On) ,OTL(seqControl.On) ,OTU(System.Stopping) ] ,OTU(HMI.From_HMI.ClearConveyor_PB) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Verify Camera]]></Comment>
      <Text><![CDATA[[GEQ(System.Access_Level,1) XIO(Bit_Alarm_Active) XIO(System.Alarm) XIO(System.Manual) XIO(seqControl.On) XIC(System.Homed) XIC(seqAbort.Complete) XIC(permVision) XIC(Bit_Camera_Cal_Perm) OTE(HMI.To_HMI.VerifyEnable) ,XIC(HMI.From_HMI.Verify_PB) [XIC(HMI.To_HMI.VerifyEnable) OTL(seqControl.On) OTL(seqVer_Camera.On) OTU(seqVer_Camera.Complete) ,OTU(HMI.From_HMI.Verify_PB) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Stop button is pressed from HMI]]></Comment>
      <Text><![CDATA[[XIC(HMI.From_HMI.Stop_PB) [OTL(System.Stopping) ,OTU(HMI.From_HMI.Stop_PB) ] ,XIO(System.Stopping) OTE(HMI.To_HMI.StopEnable) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Abort button is pressed from HMI]]></Comment>
      <Text><![CDATA[XIC(HMI.From_HMI.Abort_PB)[XIC(System.Homed) XIO(seqAbort.On) NEQ(seqAbort.Step,0) OTL(seqAbort.Reset) ,XIC(System.Homed) EQU(seqAbort.Step,0) ONS(Machine_Oneshots[0].7) [OTL(seqAbort.On) ,OTU(seqAbort.Complete) ,OTU(seqControl.On) ] ,XIC(System.Homed) XIC(seqAbort.On) [NEQ(seqAbort.Step,0) ,XIC(seqAbort.Fault) ] [OTL(seqAbort.Reset) ,OTL(seqHoming.Reset) ,OTU(seqAbort.On) ] ,OTU(HMI.From_HMI.Abort_PB) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step mode button is pressed on HMI
add sequences you plan to SS below


]]></Comment>
      <Text><![CDATA[[XIC(HMI.From_HMI.Step_Mode_PB) XIO(System.Stepping) OTL(System.Stepping) ,XIO(HMI.From_HMI.Step_Mode_PB) XIC(System.Stepping) OTU(System.Stepping) ,XIC(System.Stepping) [OTE(seqAbort.StepMode) ,OTE(seqHoming.StepMode) ,OTE(seqCanInsert.StepMode) ,OTE(seqTransferGripper.StepMode) ,OTE(seqHitchPunch.StepMode) ,OTE(seqCal_Camera.StepMode) ] ,[XIC(System.Stepping) ,XIC(Bit_RobotOnlyStepMode) ] OTE(seqRobot.StepMode) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Maint mode button is pressed from HMI

]]></Comment>
      <Text><![CDATA[[[XIC(System.Paused) ,XIO(seqRobot.On) XIO(seqVer_Camera.On) XIO(seqAbort.On) XIO(seqCanInsert.On) XIO(seqControl.On) XIO(seqConveyor_Anode.On) XIO(seqConveyor_Cathode.On) XIO(seqHitchPunch.On) XIO(seqOpHitch.On) XIO(seqHoming.On) XIO(seqTransferGripper.On) XIC(bitAllLocationsLoaded) ] OTE(HMI.To_HMI.ManualPBEnable) ,XIC(HMI.From_HMI.Manual_Mode) XIO(System.Manual) OTL(System.Manual) ,XIO(HMI.From_HMI.Manual_Mode) XIC(System.Manual) OTU(System.Manual) ,LEQ(System.Access_Level,1) OTU(HMI.From_HMI.Manual_Mode) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Pause button is pressed from HMI]]></Comment>
      <Text><![CDATA[[[XIC(HMI.From_HMI.Pause_PB) ,XIC(System.Manual) ONS(Machine_Oneshots[0].9) ] [XIO(System.Pause_IP) XIO(System.Paused) OTL(System.Pause_IP) ,OTU(HMI.From_HMI.Pause_PB) ] ,[XIC(System.Running) ,XIO(System.Manual) XIO(System.Paused) ] OTE(HMI.To_HMI.PauseEnable) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Proceed button pressed from HMI
add each sequence you have below


]]></Comment>
      <Text><![CDATA[[XIC(HMI.From_HMI.Proceed_PB) [ONS(Machine_Oneshots[0].10) [XIC(System.Paused) [XIO(seqControl.On) ,XIC(seqControl.On) XIO(System.Manual) ] OTU(System.Paused) ,XIC(seqAbort.Fault) OTU(seqAbort.Fault) ,XIC(seqHoming.Fault) OTU(seqHoming.Fault) ,XIC(seqControl.Fault) OTU(seqControl.Fault) ,XIC(seqHitchPunch.Fault) OTU(seqHitchPunch.Fault) ,XIC(seqOpHitch.Fault) OTU(seqOpHitch.Fault) ,XIC(seqRobot.Fault) OTU(seqRobot.Fault) ,XIC(seqConveyor_Anode.Fault) OTU(seqConveyor_Anode.Fault) ,XIC(seqConveyor_Cathode.Fault) OTU(seqConveyor_Cathode.Fault) ,XIC(seqWebDancer.Fault) [OTU(seqWebDancer.Fault) ,OTL(Dancer_Payout.Reset) ,OTL(Dancer_Takeup.Reset) ] ,XIC(seqTransferGripper.Fault) OTU(seqTransferGripper.Fault) ,XIC(seqCanInsert.Fault) OTU(seqCanInsert.Fault) ,XIC(seqManualHitch.Fault) OTU(seqManualHitch.Fault) ,XIC(seqCal_Camera.Fault) OTU(seqCal_Camera.Fault) ,XIC(SeqClearConveyor.Fault) OTU(SeqClearConveyor.Fault) ,XIC(seqManualPunch.Fault) OTU(seqManualPunch.Fault) ,OTU(seqVer_Camera.Fault) OTU(seqPIA.Fault) ] ,OTU(HMI.From_HMI.Proceed_PB) ] ,[XIC(System.Paused) ,XIC(System.Alarm) ] XIO(System.Manual) XIO(I_Estop_NOT_OK) OTE(HMI.To_HMI.ProceedEnable) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Continue Main Control Schemes

]]></Comment>
      <Text><![CDATA[NOP();]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Add Servo Velocity monitor for all axes below during pause situation

]]></Comment>
      <Text><![CDATA[[XIC(System.Pause_IP) LIM(-0.1,drvCanInsert.AverageVelocity,0.1) LIM(-0.5,drvTransferRotary.AverageVelocity,0.5) LIM(-0.5,drvTransferLinear.AverageVelocity,0.5) EQU(s800.Robot.Percent_Move_Complete,100) TON(Machine_Timers[1],?,?) ,XIC(Machine_Timers[1].DN) [OTL(System.Paused) ,OTU(System.Pause_IP) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[System Running Status]]></Comment>
      <Text><![CDATA[XIC(Permissive_Interlocks_OK)XIC(Permissive_Motion_OK)XIC(Permissive_Pneumatics_OK)XIC(Permissive_Vacuum_OK)XIC(seqControl.On)XIO(seqControl.Fault)XIO(System.Pause_IP)XIO(System.Paused)OTE(System.Running);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Sequence Activations
add each sequence you have below


]]></Comment>
      <Text><![CDATA[XIO(System.Manual)XIO(System.Stopping)XIC(Bit_Start_Program_Sequences)[XIO(seqControl.On) OTL(seqControl.On) ,XIC(seqControl.On) XIO(seqRobot.On) OTL(seqRobot.On) ,XIC(seqRobot.On) XIO(seqHitchPunch.On) OTL(seqHitchPunch.On) ,XIC(seqHitchPunch.On) XIO(seqTransferGripper.On) OTL(seqTransferGripper.On) ,XIC(seqTransferGripper.On) XIO(seqWebDancer.On) [OTL(seqWebDancer.On) ,OTL(Dancer_Payout.Reset) ,OTL(Dancer_Takeup.Reset) ] ,XIC(seqWebDancer.On) XIO(seqCanInsert.On) [OTL(seqCanInsert.On) ,OTL(seqConveyor_Anode.On) ,OTL(seqConveyor_Cathode.On) ] ,OTU(Bit_Start_Program_Sequences) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Stopping...
add each sequence you have below


]]></Comment>
      <Text><![CDATA[XIO(seqOpHitch.On)XIO(seqCal_Camera.On)XIO(seqVer_Camera.On)XIO(seqHitchPunch.On)XIO(seqRobot.On)XIO(seqConveyor_Anode.On)XIO(seqConveyor_Cathode.On)XIO(seqWebDancer.On)XIO(seqTransferGripper.On)XIO(seqCanInsert.On)XIO(SeqClearConveyor.On)XIO(seqManualPunch.On)[OTU(System.Stopping) ,OTU(seqControl.On) ,OTU(seqRobot.Complete) ,OTU(seqHitchPunch.Complete) ,OTU(seqTransferGripper.Complete) ,OTU(seqCanInsert.Complete) ,OTU(seqConveyor_Anode.Complete) ,OTU(seqConveyor_Cathode.Complete) ,OTU(seqOpHitch.Complete) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Home Complete bit
add each axis you have below


]]></Comment>
      <Text><![CDATA[XIC(seqHoming.Complete)XIC(srvCanInsertAxis.Servo.statHomed)XIC(srvTransferRotaryGripperAxis.Servo.statHomed)XIC(srvTransferGripperLinearAxis.Servo.statHomed)OTE(System.Homed);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[System Alarm Status
add each sequence you have below


]]></Comment>
      <Text><![CDATA[[XIC(seqAbort.Fault) ,XIC(seqHoming.Fault) ,XIC(seqControl.Fault) ,XIC(seqHitchPunch.Fault) ,XIC(seqOpHitch.Fault) ,XIC(seqVer_Camera.Fault) ,XIC(seqRobot.Fault) ,XIC(seqWebDancer.Fault) ,XIC(seqTransferGripper.Fault) ,XIC(seqCanInsert.Fault) ,XIC(seqConveyor_Anode.Fault) ,XIC(seqConveyor_Cathode.Fault) ,XIC(seqManualHitch.Fault) ,XIC(seqManualPunch.Fault) ,XIC(seqCal_Camera.Fault) ,XIC(seqPIA.Fault) ,XIC(SeqClearConveyor.Fault) ]OTE(System.Alarm);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIO(Bit_Camera_Cal_Perm)OTE(bitCalibrationPerm_Not);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[If stopped on the steps below then we are waiting for process]]></Comment>
      <Text><![CDATA[[EQU(seqRobot.Step,505) ,EQU(seqRobot.Step,414) ,EQU(seqRobot.Step,310) ]TON(waitproctmr,?,?);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[[XIC(Pia.Machine.Trans_In_Process) ,XIC(waitproctmr.DN) ]OTE(bitWaitingForProcess);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(HMI.To_HMI.Notification)OTE(bitWaitingForUser);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[Mach1_State(Mach1State,System,seqControl.On,Bit_Alarm_Active,seqAbort.On,seqRobot.On,seqControl.Complete,seqCal_Camera.On,seqVer_Camera.On,seqHoming.On,I_Estop_NOT_OK,bitCalibrationPerm_Not,bitVericationPerm_Not,bitWaitingForUser,bitWaitingForProcess,Settings.WaitForProcDelay.Value,Settings.WaitForUserDelay.Value,I_Interlocks_Bypassed,O_Stack_Red,O_Stack_Amber,O_Stack_Green);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[COP(Mach1State.intState,HMI.To_HMI.Mach1_State,1)COP(Mach1State.intMode,HMI.To_HMI.Mach1_Mode,1);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[COP(k_STR_Status[System.Status],HMI.To_HMI.TopTaskBar_StatusText,1)COP(k_DINT_Status[System.Status],HMI.To_HMI.TopTaskBar_StatusColor,1);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Status = Estopped]]></Comment>
      <Text><![CDATA[XIC(I_Estop_NOT_OK)MOV(0,System.Status);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Status = Not Homed]]></Comment>
      <Text><![CDATA[XIO(I_Estop_NOT_OK)XIO(System.Pause_IP)XIO(System.Alarm)XIO(System.Paused)XIO(System.Manual)XIO(System.Homed)XIO(seqHoming.On)XIO(seqAbort.On)MOV(1,System.Status);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Status = Homing]]></Comment>
      <Text><![CDATA[XIO(I_Estop_NOT_OK)XIO(System.Pause_IP)XIO(System.Alarm)XIO(System.Paused)XIO(System.Manual)XIO(System.Homed)XIC(seqHoming.On)XIO(bitWaitingForUser)XIO(bitWaitingForProcess)MOV(2,System.Status);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Status = Not Initialized
Delay Timer to mask time between when abort is complete and seqControl.complete turns on (approx 1 scan)
]]></Comment>
      <Text><![CDATA[[XIO(I_Estop_NOT_OK) XIO(System.Alarm) XIC(System.Homed) XIO(System.Paused) XIO(System.Running) XIO(seqAbort.On) [XIO(seqControl.Complete) ,XIO(permVision) ] TON(NotInitDelayTmr,?,?) ,XIC(NotInitDelayTmr.DN) MOV(3,System.Status) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Status = Running]]></Comment>
      <Text><![CDATA[XIO(I_Estop_NOT_OK)XIO(System.Alarm)XIO(System.Manual)XIC(System.Homed)XIO(System.Stepping)XIO(seqAbort.On)XIO(System.Stopping)XIC(System.Running)XIO(bitWaitingForUser)XIO(bitWaitingForProcess)MOV(4,System.Status);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Status = Waiting for User]]></Comment>
      <Text><![CDATA[XIO(I_Estop_NOT_OK)XIO(System.Alarm)XIC(bitWaitingForUser)MOV(30,System.Status);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Status = Waiting for Process]]></Comment>
      <Text><![CDATA[XIO(I_Estop_NOT_OK)XIO(System.Alarm)XIC(bitWaitingForProcess)MOV(31,System.Status);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Status = Pausing

]]></Comment>
      <Text><![CDATA[XIO(I_Estop_NOT_OK)XIC(System.Pause_IP)XIO(bitWaitingForUser)XIO(bitWaitingForProcess)MOV(5,System.Status);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Status = Paused]]></Comment>
      <Text><![CDATA[XIO(I_Estop_NOT_OK)XIO(System.Pause_IP)XIO(System.Alarm)XIO(System.Manual)XIO(Bit_Alarm_Active)XIC(System.Paused)MOV(6,System.Status);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Status = Step Mode

]]></Comment>
      <Text><![CDATA[XIO(I_Estop_NOT_OK)XIC(seqControl.On)XIO(System.Alarm)XIO(System.Manual)XIC(System.Homed)XIO(seqAbort.On)XIC(System.Running)XIC(System.Stepping)XIO(bitWaitingForUser)XIO(bitWaitingForProcess)MOV(7,System.Status);]]></Text>
    </Rung>
    <Rung Type="N">
