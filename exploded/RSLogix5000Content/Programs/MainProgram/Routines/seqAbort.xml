<?xml version="1.0" encoding="utf-8"?>
<Routine Name="seqAbort" Type="RLL">
  <Description><![CDATA[Abort Sequence]]></Description>
  <RLLContent>
    <Rung Type="N">
      <Comment><![CDATA[Reset the abort sequence

]]></Comment>
      <Text><![CDATA[XIC(seqAbort.Reset)[CLR(seqAbort.Step) ,OTU(seqAbort.On) ,OTU(seqAbort.Fault) ,CLR(seqAbort.Fault_Code) ,OTU(seqAbort.Complete) ,OTU(seqAbort.Reset) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Permissive for sequence


]]></Comment>
      <Text><![CDATA[XIC(Permissive_Motion_OK)XIC(Permissive_Interlocks_OK)XIC(Permissive_Pneumatics_OK)XIC(Permissive_Vacuum_OK)XIC(Permissive_Alarm_OK_CanInsert)XIC(Permissive_Alarm_OK_TransferGripper)XIC(Permissive_Alarm_OK_Robot)XIO(seqAbort.Fault)XIC(seqAbort.On)XIO(System.Paused)XIO(System.Pause_IP)OTE(seqAbort.Perm);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[If Not in Step Mode Hold Step Next Off
]]></Comment>
      <Text><![CDATA[XIO(seqAbort.StepMode)OTU(seqAbort.StepNext);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 0: Run machine Sequence Resets and init vac cylinders



]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,0)XIC(seqAbort.On)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ]CONCAT(Message_Abort[0],K_Str_Blank,seqAbort.Status)[OTU(seqControl.On) OTU(seqControl.Fault) ,NEQ(seqHoming.Step,1) OTL(seqHoming.Reset) ,OTU(bitAbortAfterManSeq) ,OTL(seqRobot.Reset) ,OTL(seqConveyor_Anode.Reset) OTL(seqConveyor_Cathode.Reset) OTL(SeqClearConveyor.Reset) ,OTL(seqResetDie.Reset) OTL(seqHitchPunch.Reset) OTL(seqOpHitch.Reset) ,OTL(seqCanInsert.Reset) OTL(seqTransferGripper.Reset) ,OTL(seqWebDancer.Reset) ,OTL(Dancer_Payout.Reset) OTL(Dancer_Takeup.Reset) ,OTL(seqManualHitch.Reset) OTL(seqManualPunch.Reset) ,OTL(seqVer_Camera.Reset) OTL(seqCal_Camera.Reset) ,OTL(srvCanInsertAxis.Command.Stop_Req) ,OTL(srvTransferRotaryGripperAxis.Command.Stop_Req) ,OTL(srvTransferGripperLinearAxis.Command.Stop_Req) ,OTL(s800.Commands.Brake_Req) ,OTL(actInsulatorVac.ACT.Abort) OTL(actCanInsertVac.ACT.Abort) ,OTL(actStackFixtureVac.ACT.Abort) OTL(actDieVac.ACT.Abort) ,OTL(actPMVac.ACT.Abort) ,OTU(O_Vision_Light_On) OTU(O_Calibration_light_On) ,OTU(O_Overhead_Light) ,OTU(bitLoadSettings) OTU(bitLoadRecipe) ,JSR(subClearProgramBits,0) ,[MOV(2,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 2: Stopping Robot]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,2)XIC(seqAbort.Perm)CONCAT(Message_Abort[2],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][TON(Machine_Timers[11],?,?) ,OTL(s800.Commands.Brake_Req) ,XIC(Machine_Timers[11].DN) [MOV(5,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 5: Wait for robot movement to end]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,5)XIC(seqAbort.Perm)CONCAT(Message_Abort[3],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ]XIO(s800.Commands.Brake_Req)XIO(s800.Robot.statToolMode)XIO(srvCanInsertAxis.Command.Stop_Req)XIO(srvTransferRotaryGripperAxis.Command.Stop_Req)XIO(srvTransferGripperLinearAxis.Command.Stop_Req)EQU(s800.Robot.Percent_Move_Complete,100)EQU(s800.Commands.Approach_Height,0)[OTL(actStackPressure.ACT.Retract_Req) ,XIC(actStackPressure.ACT.Fault) OTL(seqAbort.Fault) ,XIC(actStackPressure.ACT.Retract_Complete) [XIC(bitCalSlideInMachine) MOV(7,seqAbort.Step) ,XIO(bitCalSlideInMachine) MOV(10,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 7: Safety Check to Verify Cal Slide is Removed]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,7)XIC(seqAbort.Perm)CONCAT(Message_Abort[4],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][XIC(I_EOAT_Vac) [OTU(HMI.From_HMI.Msgbox_Button_1) ,OTU(HMI.From_HMI.Msgbox_Button_2) ,OTU(HMI.To_HMI.Show_MSG_2) ] ,XIO(I_EOAT_Vac) [COP(Message_Abort[seqAbort.Step],HMI.To_HMI.Msgbox_Prompt,1) ,COP(Message_Cal_Popup[1],HMI.To_HMI.Msgbox_Button_1,1) ,COP(Message_Cal_Popup[2],HMI.To_HMI.Msgbox_Button_2,1) ,OTL(HMI.To_HMI.Show_MSG_2) ,XIC(HMI.From_HMI.Msgbox_Button_1) [MOV(10,seqAbort.Step) ,OTU(bitCalSlideInMachine) ,OTU(HMI.From_HMI.Msgbox_Button_1) ,OTU(HMI.To_HMI.Show_MSG_2) ,OTU(seqAbort.StepNext) ] ,XIC(HMI.From_HMI.Msgbox_Button_2) OTU(HMI.From_HMI.Msgbox_Button_2) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 10: Safety Check that robot was not moved]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,10)XIC(seqAbort.Perm)CONCAT(Message_Abort[5],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][XIO(Bit_Robot_Moved) [MOV(22,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ,XIC(Bit_Robot_Moved) [MOV(20,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 20: Please align robot to markers]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,20)XIC(seqAbort.Perm)CONCAT(Message_Abort[6],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][COP(Message_Abort_Popup[5],HMI.To_HMI.Msgbox_Prompt,1) ,COP(Message_Abort_Popup[6],HMI.To_HMI.Msgbox_Button_1,1) ,COP(Message_Abort_Popup[7],HMI.To_HMI.Msgbox_Button_2,1) ,OTL(HMI.To_HMI.Show_MSG_2) ,[ADD(s800_Home_Check._1,20,Joint1_USL) ,SUB(s800_Home_Check._1,20,Joint1_LSL) ] ,[ADD(s800_Home_Check._2,20,Joint2_USL) ,SUB(s800_Home_Check._2,20,Joint2_LSL) ] ,XIC(HMI.From_HMI.Msgbox_Button_1) [LIM(Joint1_LSL,s800.Joint_Current_Value._1,Joint1_USL) LIM(Joint2_LSL,s800.Joint_Current_Value._2,Joint2_USL) LIM(0,s800.Joint_Current_Value._3,30) [MOV(22,seqAbort.Step) ,OTU(Bit_Robot_Power_Loss) OTU(Bit_Robot_Moved) ] ,OTU(HMI.From_HMI.Msgbox_Button_1) ,OTU(HMI.To_HMI.Show_MSG_2) ] ,XIC(HMI.From_HMI.Msgbox_Button_2) [OTU(HMI.From_HMI.Msgbox_Button_2) ,OTU(HMI.To_HMI.Show_MSG_3) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 22: Decide if in bad zone to travel to abort position]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,22)XIC(seqAbort.Perm)CONCAT(Message_Abort[7],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][GRT(s800.Joint_Current_Value._1,Robot_Unsafe_Loc) [MOV(30,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ,LES(s800.Joint_Current_Value._1,Robot_Unsafe_Loc) [MOV(25,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 25: In bad area to goto abort, travel to abort waypoint]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,25)XIC(seqAbort.Perm)CONCAT(Message_Abort[8],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][ONS(Machine_Oneshots[5].16) [MOV(s800.Robot.MotionCounter,intMotionCounter) ,COP(s800.LocationConfig[Loc_Abort_Waypoint],s800.LocationConfig[iLocTemp],1) ,MOV(iLocTemp,s800.Commands.MoveLocationIndex) ,OTL(s800.Commands.Jump_Req) ] ,XIC(s800.Robot.statFaulted) OTL(seqAbort.Fault) ,XIO(s800.Commands.Jump_Req) NEQ(s800.Robot.MotionCounter,intMotionCounter) XIC(s800.Robot.Jump_Complete) [MOV(30,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 30: Move Robot to Safe Travel Height, then to abort location
]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,30)XIC(seqAbort.Perm)CONCAT(Message_Abort[10],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][OTU(Bit_Robot_Moved) ,ONS(Machine_Oneshots[4].1) [MOV(s800.Robot.MotionCounter,intMotionCounter) ,COP(s800.LocationConfig[Loc_Abort],s800.LocationConfig[iLocTemp],1) ,MOV(iLocTemp,s800.Commands.MoveLocationIndex) ,OTL(s800.Commands.Jump_Req) ] ,XIC(s800.Robot.statFaulted) OTL(seqAbort.Fault) ,XIO(s800.Commands.Jump_Req) NEQ(s800.Robot.MotionCounter,intMotionCounter) XIC(s800.Robot.Jump_Complete) [MOV(40,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 40: Blow Off Parts]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,40)XIC(seqAbort.Perm)CONCAT(Message_Abort[11],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][OTL(actRobotVac.ACT.Retract_Req) ,XIC(actRobotVac.ACT.Retract_Complete) [MOV(50,seqAbort.Step) ,OTL(actRobotVac.ACT.Abort) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 50: Move Robot to Home
]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,50)XIC(seqAbort.Perm)CONCAT(Message_Abort[12],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][ONS(Machine_Oneshots[4].2) [MOV(s800.Robot.MotionCounter,intMotionCounter) ,COP(s800.LocationConfig[Loc_Home],s800.LocationConfig[iLocTemp],1) ,MOV(iLocTemp,s800.Commands.MoveLocationIndex) ,OTL(s800.Commands.Jump_Req) ] ,XIC(s800.Robot.statFaulted) OTL(seqAbort.Fault) ,XIO(s800.Commands.Jump_Req) NEQ(s800.Robot.MotionCounter,intMotionCounter) XIC(s800.Robot.Jump_Complete) [MOV(60,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 60: Vacuum Check]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,60)XIC(seqAbort.Perm)CONCAT(Message_Abort[13],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][OTL(actRobotVac.ACT.Extend_Req) ,TON(Machine_Timers[8],?,?) ,XIC(actRobotVac.ACT.Extend_Complete) XIC(Machine_Timers[8].DN) [XIC(I_EOAT_Vac) [MOV(10,seqAbort.Step) ,OTL(Bit_Robot_Part_Stuck_Trigger) ,OTL(seqAbort.Fault) ] ,XIO(I_EOAT_Vac) [MOV(70,seqAbort.Step) ,OTL(actRobotVac.ACT.Abort) ] ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 70: Home Insulator Cylinder]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,70)XIC(seqAbort.Perm)CONCAT(Message_Abort[15],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][OTL(actInsulator.ACT.Retract_Req) ,XIC(actInsulator.ACT.Fault) OTL(seqAbort.Fault) ,XIC(actInsulator.ACT.Retract_Complete) [MOV(90,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 90: Home Die Punch Cylinder]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,90)XIC(seqAbort.Perm)CONCAT(Message_Abort[16],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][OTL(actDiePunch.ACT.Retract_Req) ,XIC(actDiePunch.ACT.Fault) OTL(seqAbort.Fault) ,XIC(actDiePunch.ACT.Retract_Complete) [MOV(110,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 110: Close Gripper Cylinder]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,110)XIC(seqAbort.Perm)CONCAT(Message_Abort[17],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][OTL(actGripper.ACT.Retract_Req) ,XIC(actGripper.ACT.Fault) OTL(seqAbort.Fault) ,XIC(actGripper.ACT.Retract_Complete) [MOV(115,seqAbort.Step) ,OTL(actGripper.ACT.Abort) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 115: Home Pre Die Fixed Hitch Cylinder]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,115)XIC(seqAbort.Perm)CONCAT(Message_Abort[18],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][OTL(actFixedHitchPreDie.ACT.Extend_Req) ,XIC(actFixedHitchPreDie.ACT.Fault) OTL(seqAbort.Fault) ,XIC(actFixedHitchPreDie.ACT.Extend_Complete) [MOV(120,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 120: Home Post Die Fixed Hitch Cylinder]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,120)XIC(seqAbort.Perm)CONCAT(Message_Abort[19],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][OTL(actFixedHitchPostDie.ACT.Extend_Req) ,XIC(actFixedHitchPostDie.ACT.Fault) OTL(seqAbort.Fault) ,XIC(actFixedHitchPostDie.ACT.Extend_Complete) [MOV(125,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 125: Home Moving Hitch Cylinder]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,125)XIC(seqAbort.Perm)CONCAT(Message_Abort[20],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][OTL(actMovingHitch.ACT.Retract_Req) ,XIC(actMovingHitch.ACT.Fault) OTL(seqAbort.Fault) ,XIC(actMovingHitch.ACT.Retract_Complete) [MOV(130,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 130: Home Indexer Cylinder

]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,130)XIC(seqAbort.Perm)CONCAT(Message_Abort[21],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][OTL(actIndexer.ACT.Retract_Req) ,XIC(actIndexer.ACT.Fault) OTL(seqAbort.Fault) ,XIC(actIndexer.ACT.Retract_Complete) [MOV(135,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 135: Abort Robot Vacuum ]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,135)XIC(seqAbort.Perm)CONCAT(Message_Abort[22],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][OTL(actRobotVac.ACT.Abort) ,MOV(140,seqAbort.Step) ,OTU(seqAbort.StepNext) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 140: Lock Drawers
]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,140)XIC(seqAbort.Perm)CONCAT(Message_Abort[23],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ]XIC(I_Left_Can_Drawer_Closed)XIC(I_Left_Insul_Drawer_Closed)XIC(I_Right_Can_Drawer_Closed)XIC(I_Right_Insul_Drawer_Closed)XIC(I_PM_Drawer_Closed)[[OTL(actLCanDrawerLock.ACT.Extend_Req) ,OTL(actLInsulatorDrawerLock.ACT.Extend_Req) ,OTL(actRCanDrawerLock.ACT.Extend_Req) ,OTL(actRInsulatorDrawerLock.ACT.Extend_Req) ,OTL(actPMDrawerLock.ACT.Extend_Req) ] ,[XIC(actLCanDrawerLock.ACT.Fault) ,XIC(actLInsulatorDrawerLock.ACT.Fault) ,XIC(actRCanDrawerLock.ACT.Fault) ,XIC(actRInsulatorDrawerLock.ACT.Fault) ,XIC(actPMDrawerLock.ACT.Fault) ] OTL(seqAbort.Fault) ,XIC(actLCanDrawerLock.ACT.Extend_Complete) XIC(actLInsulatorDrawerLock.ACT.Extend_Complete) XIC(actRCanDrawerLock.ACT.Extend_Complete) XIC(actRInsulatorDrawerLock.ACT.Extend_Complete) XIC(actPMDrawerLock.ACT.Extend_Complete) [MOV(145,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[determine the state of the LnL grippers, make sure they are extended or retracted with respect to the AOI
if aoi doesn't have ext or ret, use io to determine what to do
probably overthinking and this will never happen]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,145)XIC(seqAbort.Perm)CONCAT(Message_Abort[26],K_Str_Blank,seqAbort.Status)[[XIO(actAnodeLNLGripper.ACT.Retract_Complete) XIO(actAnodeLNLGripper.ACT.Extend_Complete) [XIC(DigitalInput4.4) OTL(actAnodeLNLGripper.ACT.Extend_Req) ,XIC(DigitalInput4.3) OTL(actAnodeLNLGripper.ACT.Retract_Req) ,XIO(DigitalInput4.4) XIO(DigitalInput4.3) OTL(actAnodeLNLGripper.ACT.Retract_Req) ] ,XIO(I_AnodeCassette_DetectedRaised) OTL(actAnodeLNLGripper.ACT.Retract_Req) ] ,[XIO(actCathodeLNLGripper.ACT.Retract_Complete) XIO(actCathodeLNLGripper.ACT.Extend_Complete) [XIC(DigitalInput4.6) OTL(actCathodeLNLGripper.ACT.Extend_Req) ,XIC(DigitalInput4.5) OTL(actCathodeLNLGripper.ACT.Retract_Req) ,XIO(DigitalInput4.6) XIO(DigitalInput4.5) OTL(actCathodeLNLGripper.ACT.Retract_Req) ] ,XIO(I_CathodeCassette_DetectedRaised) OTL(actCathodeLNLGripper.ACT.Retract_Req) ] ,[XIC(actAnodeLNLGripper.ACT.Fault) ,XIC(actCathodeLNLGripper.ACT.Fault) ] OTL(seqAbort.Fault) ,[XIC(actAnodeLNLGripper.ACT.Retract_Complete) ,XIC(actAnodeLNLGripper.ACT.Extend_Complete) ] [XIC(actCathodeLNLGripper.ACT.Retract_Complete) ,XIC(actCathodeLNLGripper.ACT.Extend_Complete) ] MOV(150,seqAbort.Step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Retract LnL cylinders.. Might already be retracted, might be up holding cassette..
If the gripper is not closed, cassette will come down with LnL]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,150)XIC(seqAbort.Perm)CONCAT(Message_Abort[27],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][OTL(actLNLAnode.ACT.Retract_Req) OTL(actLNLCathode.ACT.Retract_Req) ,[XIC(actLNLAnode.ACT.Fault) ,XIC(actLNLCathode.ACT.Fault) ] OTL(seqAbort.Fault) ,XIC(actLNLAnode.ACT.Retract_Complete) XIC(actLNLCathode.ACT.Retract_Complete) [MOV(155,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[if either conveyor says it's ready, and there is a cassette present, gripper closed then signal picked to the conveyor
presumably the system was aborted during the handoff to the grippers
if the cassette came back down with the LnL on aborting, we'll just raise it again and attempt to pick from it]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,155)CONCAT(Message_Abort[28],K_Str_Blank,seqAbort.Status)[ONS(onsBits[0].5) OTU(bAnConvWasReady) OTU(bCathConvWasReady) ,XIC(I_AnodeLane_Running) XIC(I_CathodeLane_Running) [XIC(I_Anode_CassetteReadyforProcessing) XIC(I_AnodeCassette_DetectedRaised) XIC(actAnodeLNLGripper.ACT.Extend_Complete) [OTE(iSigToAnodeConv_CassettePicked.2) ,OTL(bAnConvWasReady) ] ,XIC(I_Cathode_CassetteReadyforProcessing) XIC(I_CathodeCassette_DetectedRaised) XIC(actCathodeLNLGripper.ACT.Extend_Complete) [OTE(iSigToCathodeConv_CassettePicked.2) ,OTL(bCathConvWasReady) ] ,XIO(iSigToAnodeConv_CassettePicked.2) XIO(iSigToCathodeConv_CassettePicked.2) MOV(192,seqAbort.Step) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 192: Home Remaining Cylinders]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,192)XIC(seqAbort.Perm)CONCAT(Message_Abort[31],K_Str_Blank,seqAbort.Status)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][OTL(actMylarLHS.ACT.Extend_Req) OTL(actMylarRHS.ACT.Extend_Req) ,XIC(actMylarLHS.ACT.Extend_Complete) XIC(actMylarRHS.ACT.Extend_Complete) [MOV(200,seqAbort.Step) ,OTU(seqAbort.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 200: Servo Move to Initial Loc Decision]]></Comment>
      <Text><![CDATA[EQU(seqAbort.Step,200)XIC(seqAbort.Perm)[XIC(System.Auto) ,XIC(seqAbort.StepNext) ][XIO(Bit_Home_Was_Requested) MOV(210,seqAbort.Step) ,XIC(Bit_Home_Was_Requested) MOV(225,seqAbort.Step) ,OTU(seqAbort.StepNext) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 210: Move Transfer Linear Axis to Aborted Position]]></Comment>
