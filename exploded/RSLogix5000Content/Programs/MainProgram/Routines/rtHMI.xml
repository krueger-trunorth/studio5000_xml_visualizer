<?xml version="1.0" encoding="utf-8"?>
<Routine Name="rtHMI" Type="RLL">
  <Description><![CDATA[Misc HMI items]]></Description>
  <RLLContent>
    <Rung Type="N">
      <Text><![CDATA[MOV(Machine_Counters[8].ACC,HISTORIAN.DiscreteDieCount);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[PIA Starting Assembly Flag]]></Comment>
      <Text><![CDATA[XIC(Parallel_PIA_PPC)[EQU(Settings.Use_PIA.Value,1) XIC(bitPIA_Process_Ready) [OTL(bitPIA_Process_Start) ,OTU(Parallel_PIA_PPC) ] ,EQU(Settings.Use_PIA.Value,0) OTU(Parallel_PIA_PPC) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Send data to HMI]]></Comment>
      <Text><![CDATA[NOP();]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Run Recipe Check]]></Comment>
      <Text><![CDATA[XIC(HMI.From_HMI.RecipeLoaded)ONS(Machine_Oneshots[0].19)[OTU(bitRecipeCheck_OK) ,JSR(subRecipe_Check,1,HMI.Recipe) ,XIO(bitRecipeCheck_OK) OTL(bitRecipeCheckFailed) ,XIC(bitRecipeCheck_OK) [CPS(rcpCheck,Machine_Run_Recipe,1) ,[XIO(seqRobot.On) XIO(seqManualPunch.On) ,XIC(seqRobot.On) EQU(seqRobot.Step,0) ,XIC(seqManualPunch.On) EQU(seqManualPunch.Step,0) ] [OTL(Bit_Update_Tray_Locations) ,OTU(Bit_Update_Tray_Locations_Done) ] ,OTU(bitRecipeCheckFailed) ] ,OTU(HMI.To_HMI.LoadRecipe) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Operator or Sequence Calls for Recipe Load

JEO - Removed code that was loading the last recipe that was run since we are now loading recipes based on die sensor and system setting. - 05/15/15
 ]]></Comment>
      <Text><![CDATA[XIO(bitLoadSettings)[XIC(bitLoadRecipe) ,XIC(bitOperatorSelectRecipe) ][ONS(Machine_Oneshots[0].21) [XIO(bitOperatorSelectRecipe) OTL(HMI.To_HMI.LoadRecipe) ,OTU(bitLoadRecipeComplete) ,OTU(Bit_Update_Tray_Locations_Done) ] ,XIO(HMI.To_HMI.LoadRecipe) XIC(HMI.From_HMI.RecipeLoaded) XIO(bitRecipeCheckFailed) XIC(bitRecipeCheck_OK) XIC(Bit_Update_Tray_Locations_Done) [OTU(bitLoadRecipe) ,OTL(bitLoadRecipeComplete) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(bitLoadRecipe)XIC(s800.Robot.statCommandActive)TOF(TrayDownLoadTmr,?,?);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Run Settings Check]]></Comment>
      <Text><![CDATA[XIC(HMI.From_HMI.SettingsLoaded)ONS(Machine_Oneshots[0].14)[JSR(subSettings_Check,1,HMI.SystemSettings) ,XIO(bitSettingsCheckOK) OTL(bitSettingCheckFailed) ,XIC(bitSettingsCheckOK) [CPS(setCheck,Settings,1) ,OTU(bitSettingCheckFailed) ] ,OTU(HMI.To_HMI.LoadSettings) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Sequence Calls for Settings Load
 ]]></Comment>
      <Text><![CDATA[XIC(bitLoadSettings)[ONS(Machine_Oneshots[0].17) [OTL(HMI.To_HMI.LoadSettings) ,OTU(bitLoadSettingsComplete) ] ,XIO(HMI.To_HMI.LoadSettings) XIC(HMI.From_HMI.SettingsLoaded) XIO(bitSettingCheckFailed) XIC(bitSettingsCheckOK) [OTU(bitLoadSettings) ,OTL(bitLoadSettingsComplete) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[System Settings saved on HMI, move settings to machine
Note that the settings is copied to the machine system settings from the queue]]></Comment>
      <Text><![CDATA[XIC(HMI.SystemSettings.Saved)ONS(Machine_Oneshots[0].20)[JSR(subSettings_Check,1,HMI.SystemSettings) ,XIO(bitSettingsCheckOK) OTL(bitSettingCheckFailed) ,XIC(bitSettingsCheckOK) [COP(setCheck,Settings,1) ,OTU(bitSettingCheckFailed) ] ,OTU(HMI.SystemSettings.Saved) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Force production when access level less than or equal to 1]]></Comment>
      <Text><![CDATA[LEQ(System.Access_Level,1)CLR(HMI.Recipe.Development);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Set recipe type string]]></Comment>
      <Text><![CDATA[[XIC(HMI.Recipe.Development.0) COP(strDevelopment,strRecipeType,1) ,XIO(HMI.Recipe.Development.0) COP(strProduction,strRecipeType,1) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[COP(Machine_Run_Recipe.RecipeName,HMI.To_HMI.ActiveRecipe,1);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[COP(System.Username,HMI.To_HMI.Username,1);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[MOV(System.Access_Level,HMI.To_HMI.AccessLevel);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Login/Logout Permitted]]></Comment>
      <Text><![CDATA[[XIO(seqControl.On) XIO(seqAbort.On) XIO(seqManualHitch.On) XIO(seqHoming.On) XIO(seqManualPunch.On) ,XIC(I_Interlocks_Bypassed) [XIC(System.Paused) ,XIC(System.Alarm) ] ]OTE(HMI.To_HMI.LogoutPerm);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(Settings.Use_PIA.Value,0)OTE(HMI.To_HMI.PIABypass);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Display]]></Comment>
      <Text><![CDATA[XIO(HMI.To_HMI.Notification)OTE(Bit_Enable_Main_Screen_Vision);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[[MOV(vbVisionPro.Cameras[0].Results.dblResults[0],HMI.To_HMI.X_Measure) ,MOV(vbVisionPro.Cameras[0].Results.dblResults[1],HMI.To_HMI.Y_Measure) ,MUL(vbVisionPro.Cameras[0].Results.dblResults[2],57.3,HMI.To_HMI.R_Measure) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Maintenance Mode Functions

]]></Comment>
      <Text><![CDATA[NOP();]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Popup Display on HMI]]></Comment>
      <Text><![CDATA[[XIC(HMI.To_HMI.Show_MSG_2) ,XIC(HMI.To_HMI.Show_MSG_3) ,XIC(HMI.To_HMI.Show_MSG_4) ,XIC(HMI.To_HMI.Show_MSG_5) ]OTE(HMI.To_HMI.Notification);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[System Settings saved on HMI, move settings to machine
Note that the settings is copied to the machine system settings from the queue]]></Comment>
      <Text><![CDATA[XIC(HMI.SystemSettings.Saved)[CPS(HMI.SystemSettings,Settings,1) ,OTU(HMI.SystemSettings.Saved) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Die Hit Counter - Increment the count of the current die]]></Comment>
      <Text><![CDATA[XIO(I_Die_Retracted)XIC(I_Die_Extended)ONS(Machine_Oneshots[0].1)CTU(Machine_Counters[8],?,?);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Feed In Webline]]></Comment>
      <Text><![CDATA[XIC(HMI.From_HMI.OpenHitchGrippers)[OTL(actFixedHitchPreDie.ACT.Retract_Req) ,OTL(actFixedHitchPostDie.ACT.Retract_Req) ,OTL(actMovingHitch.ACT.Retract_Req) ,OTU(HMI.From_HMI.OpenHitchGrippers) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Manual Close Grippers]]></Comment>
      <Text><![CDATA[XIC(HMI.From_HMI.CloseHitchGrippers)[OTL(actFixedHitchPreDie.ACT.Extend_Req) ,OTL(actFixedHitchPostDie.ACT.Extend_Req) ,OTL(actMovingHitch.ACT.Extend_Req) ,OTU(HMI.From_HMI.CloseHitchGrippers) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Manual Hitch]]></Comment>
      <Text><![CDATA[XIC(HMI.From_HMI.Manual_Hitch_Start)[XIO(seqManualPunch.On) [OTL(seqManualHitch.On) ,OTU(seqManualHitch.Complete) ,MOV(0,seqManualHitch.Step) ,MOV(HMI.To_HMI.Manual_Hitch_Number,Machine_Counters[9].PRE) ,RES(Machine_Counters[9]) ] ,OTU(HMI.From_HMI.Manual_Hitch_Start) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(HMI.From_HMI.Reset_Part_Counts)[[CLR(HMI.To_HMI.Good_Parts) ,CLR(HMI.To_HMI.Bad_Parts) ] ,OTU(HMI.From_HMI.Reset_Part_Counts) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(HMI.From_HMI.Manual_Hitch_Stop)[OTU(seqManualHitch.On) ,OTU(HMI.From_HMI.Manual_Hitch_Stop) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Manual Punch]]></Comment>
      <Text><![CDATA[XIC(HMI.From_HMI.Manual_Punch_Start)[XIO(seqManualHitch.On) [OTU(bitLoadSettingsComplete) OTU(bitLoadRecipeComplete) ,OTL(bitLoadSettings) OTL(bitLoadRecipe) ,OTL(seqManualPunch.On) ,OTL(seqControl.On) ,OTU(seqManualPunch.Complete) ,MOV(0,seqManualPunch.Step) ,MOV(HMI.To_HMI.Manual_Punch_Number,Machine_Counters[10].PRE) ,RES(Machine_Counters[10]) ] ,OTU(HMI.From_HMI.Manual_Punch_Start) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(HMI.From_HMI.Manual_Punch_Stop)[OTU(seqManualPunch.On) ,OTU(HMI.From_HMI.Manual_Punch_Stop) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Manual Read Barcode]]></Comment>
      <Text><![CDATA[XIC(HMI.From_HMI.Manual_Read_Barcode)[OTL(Barcode.Initialize) ,OTU(HMI.From_HMI.Manual_Read_Barcode) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Manual Read Barcode]]></Comment>
      <Text><![CDATA[[XIC(Barcode.Faulted) COP(String_Barcode_Error,HMI.To_HMI.Barcode_Read,1) ,XIO(Barcode.Initialize) XIC(Barcode.Complete) COP(Barcode.Returned_String,HMI.To_HMI.Barcode_Read,1) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(System.Manual)XIO(seqManualHitch.On)XIO(seqManualPunch.On)OTE(Bit_No_Manual_Hitching_IP);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Manual toggles]]></Comment>
      <Text><![CDATA[[XIC(I_LHS_Mylar_PB_Pressed) XIO(System.Running) ONS(Machine_Oneshots[5].12) [XIC(O_LHS_Mylar_On) OTL(actMylarLHS.ACT.Retract_Req) ,XIO(O_LHS_Mylar_On) OTL(actMylarLHS.ACT.Extend_Req) ] ,XIC(O_LHS_Mylar_On) OTE(O_LHS_Mylar_Light) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Manual toggles]]></Comment>
      <Text><![CDATA[[XIC(I_RHS_Mylar_PB_Pressed) XIO(System.Running) ONS(Machine_Oneshots[5].11) [XIC(O_RHS_Mylar_On) OTL(actMylarRHS.ACT.Retract_Req) ,XIO(O_RHS_Mylar_On) OTL(actMylarRHS.ACT.Extend_Req) ] ,XIC(O_RHS_Mylar_On) OTE(O_RHS_Mylar_Light) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Manual toggles]]></Comment>
      <Text><![CDATA[[XIC(I_Stack_Platform_PB_Pressed) XIO(System.Running) ONS(Machine_Oneshots[5].10) [XIC(O_Stack_Pressure_On) OTL(actStackPressure.ACT.Retract_Req) ,XIO(O_Stack_Pressure_On) OTL(actStackPressure.ACT.Extend_Req) ] ,XIC(O_Stack_Pressure_On) OTE(O_Stack_Pressure_Light) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Compute actual cycle time]]></Comment>
      <Text><![CDATA[[EQU(seqRobot.Step,725) OTL(Detect_Start) ,XIC(Detect_Start) [TON(Machine_Timers[13],?,?) ,DIV(Machine_Timers[13].ACC,1000,Convert_to_sec) ] ,XIC(Detect_Start) [EQU(seqRobot.Step,777) ,EQU(seqRobot.Step,782) ] OTL(Detect_Stop) ,XIC(Detect_Stop) [MOV(Convert_to_sec,Last_Cycle_Time) ,OTU(Detect_Stop) ,OTU(Detect_Start) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Logout Permissive
]]></Comment>
      <Text><![CDATA[XIC(HMI.To_HMI.LogoutPerm)EQU(Pia.Command,0)GRT(System.Access_Level,0)OTE(Pia.Machine.Perm_Logoff);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(HMI.From_HMI.Logout_PB)[MOV(16,Pia.Command) ,OTU(HMI.From_HMI.Logout_PB) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Copy Username from PIA]]></Comment>
      <Text><![CDATA[COP(Pia.FROM_PIA.User_ID,System.Username,1);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Copy Access Level from PIA]]></Comment>
      <Text><![CDATA[MOV(Pia.FROM_PIA.Access_Level,System.Access_Level);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Load Spool - Visibilty and Change Spool]]></Comment>
      <Text><![CDATA[[XIC(I_Discrete_Empty) ,XIC(Bit_Spool_Empty) ,XIO(System.Running) XIO(System.Manual) ,XIO(I_OOB_Front) ,XIO(I_OOB_Rear) ]XIC(bitAllLocationsLoaded)[OTE(HMI.To_HMI.LoadSpoolVisible) ,XIO(System.Running) XIO(System.Manual) XIC(HMI.From_HMI.LoadSpool) ONS(ons3) [OTU(seqOpHitch.Complete) ,OTL(seqOpHitch.On) ,OTL(seqControl.On) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[manual picture take anode snapshot
need to save with bit/path 2 after vision upgrade so that an image is saved in the display folder]]></Comment>
      <Text><![CDATA[XIC(HMI.From_HMI.SnapPicture)[[XIO(Machine_Timers[36].TT) XIO(Machine_Timers[36].DN) [OTU(bSnapPicture_LightWasOn) ,XIC(O_Vision_Light_On) OTL(bSnapPicture_LightWasOn) ] ,OTL(O_Vision_Light_On) ,TON(Machine_Timers[36],?,?) ] ,XIC(Machine_Timers[36].DN) [ONS(Machine_Oneshots[1].15) [OTU(vbVisionPro.Cameras[0].Requests.bSave1) OTL(vbVisionPro.Cameras[0].Requests.bSave2) ,XIC(Bit_Part_Type_LL) MOV(ivisAnodeLL,Camera.intInspection) MOV(ivisAnodeLL,HMI.To_HMI.MainDisplayIndex) ,XIO(Bit_Part_Type_LL) MOV(ivisAnodeSL,Camera.intInspection) MOV(ivisAnodeSL,HMI.To_HMI.MainDisplayIndex) ,CONCAT(strImageFolderPath,strImageDisplay,vbVisionPro.Cameras[0].SavePaths.strSavePath2) ,CONCAT(vbVisionPro.Cameras[0].SavePaths.strSavePath2,strBackSlash,vbVisionPro.Cameras[0].SavePaths.strSavePath2) ,CONCAT(vbVisionPro.Cameras[0].SavePaths.strSavePath2,strImage,vbVisionPro.Cameras[0].SavePaths.strSavePath2) ,DTOS(Camera.intInspection,strTemp) CONCAT(vbVisionPro.Cameras[0].SavePaths.strSavePath2,strTemp,vbVisionPro.Cameras[0].SavePaths.strSavePath2) ,CONCAT(vbVisionPro.Cameras[0].SavePaths.strSavePath2,strDotBMP,vbVisionPro.Cameras[0].SavePaths.strSavePath2) ,OTU(Camera.bitErrorInspection) OTU(Camera.bitComplete) OTL(Camera.bitRun_Request) ] ,[XIC(Camera.bitErrorInspection) ,XIC(Camera.bitError) ] OTL(Bit_Vision_Error) ,[XIC(Camera.bitErrorInspection) ,XIC(Camera.bitComplete) ] [OTL(HMI.To_HMI.ChangeMainImage) ,XIO(bSnapPicture_LightWasOn) OTU(O_Vision_Light_On) ,OTU(HMI.From_HMI.SnapPicture) ] ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[JEO - Updated to push system settings to machine settings for system name, ESN, and software change date. - 08/07/14
]]></Comment>
      <Text><![CDATA[[COP(Settings.Software_Revision.Value,HMI.Machine_Settings.SoftwareRev,1) ,COP(Settings.SystemName.Value,HMI.Machine_Settings.MachineName,1) ,COP(Settings.Software_Change_Date.Value,HMI.Machine_Settings.ModifiedDate,1) ,COP(Settings.MachineESN.Value,HMI.Machine_Settings.PartNumber,1) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Discrete Die ]]></Comment>
      <Text><![CDATA[NOP();]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Reset Die Punch Count  (Blanking Counter)]]></Comment>
      <Text><![CDATA[[[XIO(System.Manual) MOV(Machine_Counters[8].ACC,DiscreteDie.CurrentCounts) ,XIC(System.Manual) XIO(DiscreteDie.Count_Reset_PB) MOV(DiscreteDie.CurrentCounts,Machine_Counters[8].ACC) ] ,XIC(DiscreteDie.Count_Reset_PB) [COP(Message_Die_Popup[0],DiscreteDie.Message_Prompt,1) ,COP(Message_Die_Popup[1],DiscreteDie.Label_MsgBtn_1,1) ,COP(Message_Die_Popup[2],DiscreteDie.Label_MsgBtn_2,1) ,OTL(DiscreteDie.Show_MsgBtn_2) ,XIC(DiscreteDie.Msgbox_PB_1) [OTU(DiscreteDie.Msgbox_PB_1) ,OTU(DiscreteDie.Show_MsgBtn_2) ,OTU(DiscreteDie.Count_Reset_PB) ] ,XIC(DiscreteDie.Msgbox_PB_2) [OTU(DiscreteDie.Msgbox_PB_2) ,RES(Machine_Counters[8]) ,MOV(0,DiscreteDie.CurrentCounts) ,OTU(DiscreteDie.Show_MsgBtn_2) ,OTU(DiscreteDie.Count_Reset_PB) ] ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Visibility for Change Die Buttons

]]></Comment>
      <Text><![CDATA[XIO(System.Running)[XIC(System.Auto) [EQU(System.Status,10) ,XIC(DiscreteDie.Change_Die_PB) ] ,XIC(System.Manual) ]GEQ(System.Access_Level,1)OTE(DiscreteDie.Change_Die_PB_Viz);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Open Grippers and Prompt User to Change Discrete Die

]]></Comment>
      <Text><![CDATA[XIC(DiscreteDie.Change_Die_PB)[OTL(actFixedHitchPostDie.ACT.Retract_Req) ,OTL(actFixedHitchPreDie.ACT.Retract_Req) ,OTL(actMovingHitch.ACT.Retract_Req) ,COP(Message_Die_Popup[5],DiscreteDie.Message_Prompt,1) ,COP(Message_Die_Popup[3],DiscreteDie.Label_MsgBtn_1,1) ,COP(Message_Die_Popup[4],DiscreteDie.Label_MsgBtn_2,1) ,OTL(DiscreteDie.Show_MsgBtn_2) ,XIC(DiscreteDie.Msgbox_PB_1) MOV(1,DiscreteDie.Change_Die_Step) ,[XIC(DiscreteDie.Msgbox_PB_2) ,XIC(DiscreteDie.Msgbox_PB_1) ] [OTU(DiscreteDie.Msgbox_PB_2) ,OTU(DiscreteDie.Msgbox_PB_1) ,OTL(actFixedHitchPostDie.ACT.Extend_Req) ,OTL(actFixedHitchPreDie.ACT.Extend_Req) ,OTL(actMovingHitch.ACT.Extend_Req) ,OTU(DiscreteDie.Show_MsgBtn_2) ,OTU(DiscreteDie.Change_Die_PB) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Update PLC with new die data - after loaded in HMI

]]></Comment>
      <Text><![CDATA[EQU(DiscreteDie.Change_Die_Step,5)[COP(DiscreteDie.NewDieESN,DiscreteDie.CurrentDieESN,1) ,MOV(DiscreteDie.NewCounts,Machine_Counters[8].ACC) ,MOV(DiscreteDie.NewCounts,DiscreteDie.CurrentCounts) ,MOV(9,DiscreteDie.Change_Die_Step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Popup Display on HMI]]></Comment>
      <Text><![CDATA[[XIC(DiscreteDie.Show_MsgBtn_1) ,XIC(DiscreteDie.Show_MsgBtn_2) ]OTE(DiscreteDie.Notification);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Capture previous cycle time before new cycle time starts.

JEO - Created - 11/10/14]]></Comment>
      <Text><![CDATA[XIC(bCycle_TIme)ONS(onsBits[0].6)MOV(rCycle_Time,rPre_Cycle_Time);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Cycle time of current stack in process.

JEO - Created - 11/10/14]]></Comment>
      <Text><![CDATA[XIC(bCycle_TIme)[TON(tmrCycle_Time,?,?) ,MOV(tmrCycle_Time.ACC,rCycle_Time) DIV(rCycle_Time,1000,rCycle_Time) ];]]></Text>
    </Rung>
  </RLLContent>
</Routine>