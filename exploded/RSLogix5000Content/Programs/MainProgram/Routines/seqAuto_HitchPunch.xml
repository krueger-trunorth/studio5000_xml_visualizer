<?xml version="1.0" encoding="utf-8"?>
<Routine Name="seqAuto_HitchPunch" Type="RLL">
  <Description><![CDATA[Hitching/Punch Sequence]]></Description>
  <RLLContent>
    <Rung Type="N">
      <Comment><![CDATA[Reset Sequence]]></Comment>
      <Text><![CDATA[XIC(seqHitchPunch.Reset)[CLR(seqHitchPunch.Step) ,OTU(seqHitchPunch.On) ,OTU(seqHitchPunch.Fault) ,CLR(seqHitchPunch.Fault_Code) ,OTU(seqHitchPunch.Complete) ,OTU(seqHitchPunch.Reset) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Permissive for Sequence

]]></Comment>
      <Text><![CDATA[[XIC(System.Running) ,XIC(System.Manual) XIO(System.Auto) ]XIC(Permissive_Alarm_OK_HitchPunch)XIO(seqHitchPunch.Fault)XIO(System.Pause_IP)XIC(seqHitchPunch.On)XIO(System.Paused)OTE(seqHitchPunch.Perm);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[If Not In Step Mode, Hold Step Next Off]]></Comment>
      <Text><![CDATA[XIO(seqHitchPunch.StepMode)OTU(seqHitchPunch.StepNext);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 0:
Mark No Discrete at Punch]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,0)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ][OTU(Bit_Discrete_AtPunch) ,MOV(10,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 10:
Decision Maker Branch]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,10)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ][XIC(System.Stopping) XIO(Bit_WIP_InMachine) XIO(seqRobot.On) [MOV(0,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ,OTU(seqHitchPunch.On) ,OTL(seqHitchPunch.Complete) ] ,XIO(System.Stopping) XIC(HMI.From_HMI.LoadSpool) [MOV(20,seqHitchPunch.Step) ,COP(K_Str_Blank,StackData.HMI_Discrete_Data_Queue,1) ,OTL(Bit_Loading_Spool_Active) ,OTU(HMI.From_HMI.LoadSpool) ,OTU(seqHitchPunch.StepNext) ] ,[XIO(System.Stopping) ,XIC(Bit_WIP_InMachine) ] XIO(I_Discrete_Empty) XIO(Bit_Loading_Spool_Active) XIO(Bit_Spool_Empty) [XIC(Bit_Discrete_AtPunch) [MOV(150,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ] ,XIO(Bit_Discrete_AtPunch) [MOV(50,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ] ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 20: Loading Sequence
]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,20)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ][ONS(ons2) [OTU(seqOpHitch.Complete) ,OTL(seqOpHitch.On) ] ,XIC(seqOpHitch.Fault) OTL(seqHitchPunch.Fault) ,XIC(seqOpHitch.Complete) XIO(seqOpHitch.On) [MOV(0,seqHitchPunch.Step) ,OTU(Bit_Loading_Spool_Active) ,OTU(Bit_Spool_Empty) ,OTU(seqHitchPunch.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 50:
Close Fixed Grippers]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,50)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ][OTL(actFixedHitchPostDie.ACT.Extend_Req) ,OTL(actFixedHitchPreDie.ACT.Extend_Req) ,[XIC(actFixedHitchPostDie.ACT.Fault) ,XIC(actFixedHitchPreDie.ACT.Fault) ] OTL(seqHitchPunch.Fault) ,XIC(actFixedHitchPostDie.ACT.Extend_Complete) XIC(actFixedHitchPreDie.ACT.Extend_Complete) [MOV(60,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 60:
Open Moving Grippers]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,60)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ][OTL(actMovingHitch.ACT.Retract_Req) ,XIC(actMovingHitch.ACT.Fault) OTL(seqHitchPunch.Fault) ,XIC(actMovingHitch.ACT.Retract_Complete) [MOV(70,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 70:
Retract Indexer]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,70)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ][OTL(actIndexer.ACT.Retract_Req) ,XIC(actIndexer.ACT.Fault) OTL(seqHitchPunch.Fault) ,XIC(actIndexer.ACT.Retract_Complete) [MOV(80,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 80:
Close Moving Grippers]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,80)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ][OTL(actMovingHitch.ACT.Extend_Req) ,XIC(actMovingHitch.ACT.Fault) OTL(seqHitchPunch.Fault) ,XIC(actMovingHitch.ACT.Extend_Complete) [MOV(90,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 90:
Open Fixed Hitch Grippers]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,90)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ][OTL(actFixedHitchPostDie.ACT.Retract_Req) ,OTL(actFixedHitchPreDie.ACT.Retract_Req) ,[XIC(actFixedHitchPostDie.ACT.Fault) ,XIC(actFixedHitchPreDie.ACT.Fault) ] OTL(seqHitchPunch.Fault) ,XIC(actFixedHitchPostDie.ACT.Retract_Complete) XIC(actFixedHitchPreDie.ACT.Retract_Complete) [MOV(95,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 95:
Wait for dancers to home]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,95)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ]XIC(I_Payout_Home)XIC(I_Takeup_Home)[MOV(100,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 100:
Extend Indexer]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,100)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ][OTL(actIndexer.ACT.Extend_Req) ,XIC(actIndexer.ACT.Fault) OTL(seqHitchPunch.Fault) ,XIC(actIndexer.ACT.Extend_Complete) [MOV(110,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 110:
Close Fixed Grippers]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,110)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ][OTL(actFixedHitchPreDie.ACT.Extend_Req) ,OTL(actFixedHitchPostDie.ACT.Extend_Req) ,[XIC(actFixedHitchPreDie.ACT.Fault) ,XIC(actFixedHitchPostDie.ACT.Fault) ] OTL(seqHitchPunch.Fault) ,XIC(actFixedHitchPreDie.ACT.Extend_Complete) XIC(actFixedHitchPostDie.ACT.Extend_Complete) [MOV(120,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 120:
Open Moving Grippers]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,120)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ][OTL(actMovingHitch.ACT.Retract_Req) ,XIC(actMovingHitch.ACT.Fault) OTL(seqHitchPunch.Fault) ,XIC(actMovingHitch.ACT.Retract_Complete) [MOV(140,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 140:
Check OOB Sensors]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,140)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ][[[XIC(I_Discrete_Empty) ,XIC(Bit_Spool_Empty) ,XIO(I_OOB_Front) ,XIO(I_OOB_Rear) ] [MOV(0,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ] ,XIC(I_OOB_Front) XIC(I_OOB_Rear) XIO(I_Discrete_Empty) XIO(Bit_Spool_Empty) [MOV(10,seqHitchPunch.Step) ,OTL(Bit_Discrete_AtPunch) ,OTU(seqHitchPunch.StepNext) ] ] ,[XIO(I_OOB_Front) ,XIO(I_OOB_Rear) ] OTL(seqHitchPunch.Fault) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 150:
Wait for Discrete Needed by Robot, if yes turn on die vacuum]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,150)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ][XIC(Sig_Discrete_NeededBy_Robot) [OTL(actDieVac.ACT.Extend_Req) ,XIC(actDieVac.ACT.Extend_Complete) [MOV(160,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ] ] ,XIO(Sig_Discrete_NeededBy_Robot) MOV(10,seqHitchPunch.Step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 160:
Extend Die Punch
Wait for trace data here]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,160)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ]XIO(Alarms[3].28)[OTL(actDiePunch.ACT.Extend_Req) ,XIC(actDiePunch.ACT.Fault) OTL(seqHitchPunch.Fault) ,XIC(actDiePunch.ACT.Extend_Complete) [MOV(170,seqHitchPunch.Step) ,OTU(Sig_Discrete_NeededBy_Robot) ,OTU(seqHitchPunch.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 170:
Wait for Robot in position, handoff part]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,170)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ]XIC(Sig_Robot_AtPunch)[OTL(actDieVac.ACT.Retract_Req) ,XIC(actDieVac.ACT.Retract_Complete) [MOV(180,seqHitchPunch.Step) ,OTL(actDieVac.ACT.Abort) ,OTU(seqHitchPunch.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 180:
Retract Die Punch]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,180)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ][OTL(actDiePunch.ACT.Retract_Req) ,XIC(actDiePunch.ACT.Fault) OTL(seqHitchPunch.Fault) ,XIC(actDiePunch.ACT.Retract_Complete) [MOV(190,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ,OTU(Sig_Robot_AtPunch) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 190:
Vacuum Check
and notification lockout]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,190)XIC(seqHitchPunch.Perm)[XIC(System.Auto) ,XIC(seqHitchPunch.StepNext) ]XIC(Sig_Robot_Departed_fromPunch)[XIO(Sig_RobotPickedDiscrete) XIO(HMI.To_HMI.Notification) [MOV(200,seqHitchPunch.Step) ,OTL(Bit_Die_Part_Stuck_Trigger) ,OTL(seqHitchPunch.Fault) ,OTU(seqHitchPunch.StepNext) ] ,XIC(Sig_RobotPickedDiscrete) [MOV(0,seqHitchPunch.Step) ,OTU(seqHitchPunch.StepNext) ] ,OTU(Sig_Robot_Departed_fromPunch) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 200:
Manual Part Remove]]></Comment>
      <Text><![CDATA[EQU(seqHitchPunch.Step,200)XIC(seqHitchPunch.Perm)[COP(Message_Punch_Popup[3],HMI.To_HMI.Msgbox_Prompt,1) ,COP(Message_Punch_Popup[4],HMI.To_HMI.Msgbox_Button_1,1) ,COP(Message_Punch_Popup[5],HMI.To_HMI.Msgbox_Button_2,1) ,OTL(HMI.To_HMI.Show_MSG_2) ,XIC(HMI.From_HMI.Msgbox_Button_1) [MOV(0,seqHitchPunch.Step) ,OTU(HMI.From_HMI.Msgbox_Button_1) ,OTU(HMI.To_HMI.Show_MSG_2) ] ,XIC(HMI.From_HMI.Msgbox_Button_2) [OTU(HMI.From_HMI.Msgbox_Button_2) ,OTU(HMI.To_HMI.Show_MSG_2) ] ];]]></Text>
    </Rung>
  </RLLContent>
</Routine>