<?xml version="1.0" encoding="utf-8"?>
<Routine Name="seqCamera_Cal" Type="RLL">
  <Description><![CDATA[Camera Calibration]]></Description>
  <RLLContent>
    <Rung Type="N">
      <Comment><![CDATA[Reset Sequence]]></Comment>
      <Text><![CDATA[XIC(seqCal_Camera.Reset)[CLR(seqCal_Camera.Step) ,OTU(seqCal_Camera.On) ,OTU(seqCal_Camera.Fault) ,CLR(seqCal_Camera.Fault_Code) ,OTU(seqCal_Camera.Complete) ,COP(K_Str_Blank,seqCal_Camera.Status,1) ,[FLL(0,HISTORIAN.ccpCam.dblPendingVerify[0],7) ,FLL(0,HISTORIAN.ccpCam.dblPendingCal[0],26) ,CLR(HISTORIAN.ccpCam.bitPendingFail) ] ,OTU(seqCal_Camera.Reset) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Permissive for Sequence]]></Comment>
      <Text><![CDATA[XIO(I_Estop_NOT_OK)XIC(Permissive_Interlocks_OK)XIC(Permissive_Pneumatics_OK)XIC(seqControl.On)XIO(seqCal_Camera.Fault)XIC(seqCal_Camera.On)XIC(Permissive_Alarm_OK_Robot)XIO(System.Paused)XIO(System.Pause_IP)OTE(seqCal_Camera.Perm);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[If Not In Step Mode, Hold Step Next Off]]></Comment>
      <Text><![CDATA[XIO(seqCal_Camera.StepMode)OTU(seqCal_Camera.StepNext);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 0: move to safe]]></Comment>
      <Text><![CDATA[EQU(seqCal_Camera.Step,0)XIC(seqCal_Camera.Perm)CONCAT(Message_CalVer[0],K_Str_Blank,seqCal_Camera.Status)[ONS(Machine_Oneshots[8].3) [MOV(s800.Robot.MotionCounter,intMotionCounter) ,COP(s800.LocationConfig[Loc_Abort_Waypoint],s800.LocationConfig[iLocTemp],1) ,MOV(iLocTemp,s800.Commands.MoveLocationIndex) ,OTL(s800.Commands.Jump_Req) ] ,XIC(s800.Robot.statFaulted) OTL(seqCal_Camera.Fault) ,XIO(s800.Commands.Jump_Req) NEQ(s800.Robot.MotionCounter,intMotionCounter) XIC(s800.Robot.Jump_Complete) [MOV(1,seqCal_Camera.Step) ,OTU(seqCal_Camera.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 1: Init, Move robot to calibration location]]></Comment>
      <Text><![CDATA[EQU(seqCal_Camera.Step,1)XIC(seqCal_Camera.Perm)CONCAT(Message_CalVer[0],K_Str_Blank,seqCal_Camera.Status)[[OTU(seqCal_Camera.Complete) ,OTU(HMI.To_HMI.ChangeCalImage) ,MOV(-1,HMI.To_HMI.CalDisplayIndex) ,OTL(actRobotVac.ACT.Extend_Req) ] ,ONS(Machine_Oneshots[5].31) [MOV(s800.Robot.MotionCounter,intMotionCounter) ,COP(s800.LocationConfig[Loc_Cal],s800.LocationConfig[iLocTemp],1) ,MOV(iLocTemp,s800.Commands.MoveLocationIndex) ,OTL(s800.Commands.Jump_Req) ] ,XIC(s800.Robot.statFaulted) OTL(seqCal_Camera.Fault) ,XIO(s800.Commands.Jump_Req) NEQ(s800.Robot.MotionCounter,intMotionCounter) XIC(s800.Robot.Jump_Complete) [MOV(5,seqCal_Camera.Step) ,OTU(seqCal_Camera.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 5: Place on cal slide
(doors are unlocked to place slide - when seqCal_Camera.step = 5 in rtControl)]]></Comment>
      <Text><![CDATA[EQU(seqCal_Camera.Step,5)XIC(seqCal_Camera.Perm)CONCAT(Message_CalVer[2],K_Str_Blank,seqCal_Camera.Status)[COP(Message_Cal_Popup[0],HMI.To_HMI.Msgbox_Prompt,1) ,OTL(bitCalSlideInMachine) ,COP(Message_Cal_Popup[1],HMI.To_HMI.Msgbox_Button_1,1) ,COP(Message_Cal_Popup[2],HMI.To_HMI.Msgbox_Button_2,1) ,OTL(HMI.To_HMI.Show_MSG_2) ,XIC(HMI.From_HMI.Msgbox_Button_1) [MOV(10,seqCal_Camera.Step) ,OTU(HMI.From_HMI.Msgbox_Button_1) ,OTU(HMI.To_HMI.Show_MSG_2) ] ,XIC(HMI.From_HMI.Msgbox_Button_2) [OTU(HMI.From_HMI.Msgbox_Button_2) ,OTU(HMI.To_HMI.Show_MSG_2) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 10 Turn on light]]></Comment>
      <Text><![CDATA[EQU(seqCal_Camera.Step,10)XIC(seqCal_Camera.Perm)CONCAT(Message_CalVer[3],K_Str_Blank,seqCal_Camera.Status)[OTL(O_Calibration_light_On) ,TON(Machine_Timers[9],?,?) ,XIC(Machine_Timers[9].DN) [MOV(20,seqCal_Camera.Step) ,OTU(seqCal_Camera.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 20: Inspect calibration image
need to save with bit/path 2 after vision upgrade so that an image is saved in the display folder]]></Comment>
      <Text><![CDATA[EQU(seqCal_Camera.Step,20)XIC(seqCal_Camera.Perm)CONCAT(Message_CalVer[4],K_Str_Blank,seqCal_Camera.Status)[OTU(vbVisionPro.Cameras[0].Requests.bSave1) OTL(vbVisionPro.Cameras[0].Requests.bSave2) ,MOV(ivisCamera_CalCompute,Camera.intInspection) MOV(ivisCamera_CalCompute,HMI.To_HMI.CalDisplayIndex) ,ONS(Machine_Oneshots[3].11) [CONCAT(strImageFolderPath,strImageDisplay,vbVisionPro.Cameras[0].SavePaths.strSavePath2) ,CONCAT(vbVisionPro.Cameras[0].SavePaths.strSavePath2,strBackSlash,vbVisionPro.Cameras[0].SavePaths.strSavePath2) ,CONCAT(vbVisionPro.Cameras[0].SavePaths.strSavePath2,strImage,vbVisionPro.Cameras[0].SavePaths.strSavePath2) ,DTOS(Camera.intInspection,strTemp) CONCAT(vbVisionPro.Cameras[0].SavePaths.strSavePath2,strTemp,vbVisionPro.Cameras[0].SavePaths.strSavePath2) ,CONCAT(vbVisionPro.Cameras[0].SavePaths.strSavePath2,strDotBMP,vbVisionPro.Cameras[0].SavePaths.strSavePath2) ,OTU(Camera.bitErrorInspection) OTU(Camera.bitComplete) OTL(Camera.bitCalibrate_Request) ] ,[XIC(Camera.bitError) ,XIC(Camera.bitErrorInspection) OTL(HMI.To_HMI.ChangeCalImage) ] OTL(seqCal_Camera.Fault) ,XIO(Camera.bitErrorInspection) XIC(Camera.bitComplete) [MOV(25,seqCal_Camera.Step) ,COP(vbVisionPro.Cameras[0].Results.dblResults[0],HISTORIAN.ccpCam.dblPendingCal[0],26) ,OTL(HMI.To_HMI.ChangeCalImage) ,OTU(seqCal_Camera.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 25: Inspect verification image
need to save with bit/path 2 after vision upgrade so that an image is saved in the display folder]]></Comment>
      <Text><![CDATA[EQU(seqCal_Camera.Step,25)XIC(seqCal_Camera.Perm)CONCAT(Message_CalVer[5],K_Str_Blank,seqCal_Camera.Status)[XIC(System.Auto) ,XIC(seqCal_Camera.StepNext) ][OTU(vbVisionPro.Cameras[0].Requests.bSave1) OTL(vbVisionPro.Cameras[0].Requests.bSave2) ,MOV(ivisCamera_CalMeasure,Camera.intInspection) MOV(ivisCamera_CalMeasure,HMI.To_HMI.CalDisplayIndex) ,ONS(Machine_Oneshots[3].12) [CONCAT(strImageFolderPath,strImageDisplay,vbVisionPro.Cameras[0].SavePaths.strSavePath2) ,CONCAT(vbVisionPro.Cameras[0].SavePaths.strSavePath2,strBackSlash,vbVisionPro.Cameras[0].SavePaths.strSavePath2) ,CONCAT(vbVisionPro.Cameras[0].SavePaths.strSavePath2,strImage,vbVisionPro.Cameras[0].SavePaths.strSavePath2) ,DTOS(Camera.intInspection,strTemp) CONCAT(vbVisionPro.Cameras[0].SavePaths.strSavePath2,strTemp,vbVisionPro.Cameras[0].SavePaths.strSavePath2) ,CONCAT(vbVisionPro.Cameras[0].SavePaths.strSavePath2,strDotBMP,vbVisionPro.Cameras[0].SavePaths.strSavePath2) ,OTU(Camera.bitErrorInspection) OTU(Camera.bitComplete) OTL(Camera.bitRun_Request) ] ,[XIC(Camera.bitError) ,XIC(Camera.bitErrorInspection) OTL(HMI.To_HMI.ChangeCalImage) ] OTL(seqCal_Camera.Fault) ,XIO(Camera.bitErrorInspection) XIC(Camera.bitComplete) [OTL(HMI.To_HMI.ChangeCalImage) ,[MOV(vbVisionPro.Cameras[0].Results.dblResults[0],HISTORIAN.ccpCam.dblPendingVerify[0]) ,MOV(vbVisionPro.Cameras[0].Results.dblResults[1],HISTORIAN.ccpCam.dblPendingVerify[1]) ,MOV(vbVisionPro.Cameras[0].Results.dblResults[2],HISTORIAN.ccpCam.dblPendingVerify[6]) ] ,OTL(HISTORIAN.ccpCam.bitShowCal) ,MOV(30,seqCal_Camera.Step) ,OTU(seqCal_Camera.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 30: Turn off light]]></Comment>
      <Text><![CDATA[EQU(seqCal_Camera.Step,30)XIC(seqCal_Camera.Perm)CONCAT(Message_CalVer[6],K_Str_Blank,seqCal_Camera.Status)[OTU(O_Calibration_light_On) ,MOV(35,seqCal_Camera.Step) ,OTU(seqCal_Camera.StepNext) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 35: Check verification results against calibration limits]]></Comment>
      <Text><![CDATA[EQU(seqCal_Camera.Step,35)XIC(seqCal_Camera.Perm)CONCAT(Message_CalVer[7],K_Str_Blank,seqCal_Camera.Status)[XIC(System.Auto) ,XIC(seqCal_Camera.StepNext) ][[[LES(HISTORIAN.ccpCam.dblPendingVerify[0],HISTORIAN.ccpCam.dblCalLL[0]) ,GRT(HISTORIAN.ccpCam.dblPendingVerify[0],HISTORIAN.ccpCam.dblCalUL[0]) ] OTL(HISTORIAN.ccpCam.bitPendingFail.0) ,[LES(HISTORIAN.ccpCam.dblPendingVerify[1],HISTORIAN.ccpCam.dblCalLL[1]) ,GRT(HISTORIAN.ccpCam.dblPendingVerify[1],HISTORIAN.ccpCam.dblCalUL[1]) ] OTL(HISTORIAN.ccpCam.bitPendingFail.1) ,[LES(HISTORIAN.ccpCam.dblPendingVerify[6],HISTORIAN.ccpCam.dblCalLL[6]) ,GRT(HISTORIAN.ccpCam.dblPendingVerify[6],HISTORIAN.ccpCam.dblCalUL[6]) ] OTL(HISTORIAN.ccpCam.bitPendingFail.6) ] ,[MOV(40,seqCal_Camera.Step) ,OTU(seqCal_Camera.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 40: Prompt Operator to Accept or Cancel]]></Comment>
      <Text><![CDATA[EQU(seqCal_Camera.Step,40)XIC(seqCal_Camera.Perm)CONCAT(Message_CalVer[9],K_Str_Blank,seqCal_Camera.Status)[XIC(System.Auto) ,XIC(seqCal_Camera.StepNext) ][COP(Message_CalVer[9],HMI.To_HMI.Msgbox_Prompt,1) ,COP(Message_Cal_Popup[3],HMI.To_HMI.Msgbox_Button_1,1) ,COP(Message_Cal_Popup[4],HMI.To_HMI.Msgbox_Button_2,1) ,OTL(HMI.To_HMI.Show_MSG_2) ,XIC(HMI.From_HMI.Msgbox_Button_2) [MOV(55,seqCal_Camera.Step) ,OTU(HMI.From_HMI.Msgbox_Button_2) ,OTU(HMI.To_HMI.Show_MSG_2) ] ,XIC(HMI.From_HMI.Msgbox_Button_1) [OTU(HMI.From_HMI.Msgbox_Button_1) ,OTU(HMI.To_HMI.Show_MSG_2) ,OTU(Bit_Camera_Cal_Perm) ,MOV(45,seqCal_Camera.Step) ,OTU(seqCal_Camera.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 45: Update calibration on all inspections]]></Comment>
      <Text><![CDATA[EQU(seqCal_Camera.Step,45)XIC(seqCal_Camera.Perm)CONCAT(Message_CalVer[10],K_Str_Blank,seqCal_Camera.Status)[XIC(System.Auto) ,XIC(seqCal_Camera.StepNext) ][MOV(ivisCamera_CalDataVerify,Camera.intInspection) ,ONS(Machine_Oneshots[3].29) OTU(Camera.bitErrorInspection) OTU(Camera.bitComplete) OTL(Camera.bitUpdateCal_Request) ,[XIC(Camera.bitError) ,XIC(Camera.bitErrorInspection) ] OTL(seqCal_Camera.Fault) ,XIO(Camera.bitErrorInspection) XIC(Camera.bitComplete) [[COP(HISTORIAN.ccpCam.dblPendingCal[0],HISTORIAN.ccpCam.dblCurrentCal[0],26) ,COP(HISTORIAN.ccpCam.dblPendingVerify[0],HISTORIAN.ccpCam.dblCurrentVerify[0],7) ,MOV(HISTORIAN.ccpCam.bitPendingFail,HISTORIAN.ccpCam.bitCurrentFail) ,CLR(HISTORIAN.ccpCam.bitPendingFail) ] ,MOV(50,seqCal_Camera.Step) ,OTU(seqCal_Camera.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Step 50: Check verification fail bits]]></Comment>
      <Text><![CDATA[EQU(seqCal_Camera.Step,50)XIC(seqCal_Camera.Perm)CONCAT(Message_CalVer[11],K_Str_Blank,seqCal_Camera.Status)[XIC(System.Auto) ,XIC(seqCal_Camera.StepNext) ][NEQ(HISTORIAN.ccpCam.bitCurrentFail,0) OTL(bitAlarmCamCalFailed) ,[EQU(HISTORIAN.ccpCam.bitCurrentFail,0) OTL(Bit_Camera_Cal_Perm) ,MOV(55,seqCal_Camera.Step) ,OTU(seqCal_Camera.StepNext) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Remove Plate, Done
(doors are unlocked to remove slide - when seqCal_Camera.step = 55 in rtControl)]]></Comment>
      <Text><![CDATA[EQU(seqCal_Camera.Step,55)CONCAT(Message_CalVer[12],K_Str_Blank,seqCal_Camera.Status)XIO(I_EOAT_Vac)[MOV(61,seqCal_Camera.Step) ,OTU(bitCalSlideInMachine) ,OTL(actRobotVac.ACT.Abort) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Done]]></Comment>
      <Text><![CDATA[EQU(seqCal_Camera.Step,61)[OTL(seqCal_Camera.Reset) ,OTU(seqControl.On) ];]]></Text>
    </Rung>
  </RLLContent>
</Routine>