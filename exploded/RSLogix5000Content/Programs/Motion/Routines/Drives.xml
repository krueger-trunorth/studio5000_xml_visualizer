<?xml version="1.0" encoding="utf-8"?>
<Routine Name="Drives" Type="RLL">
  <Description><![CDATA[Servo drive commands]]></Description>
  <RLLContent>
    <Rung Type="N">
      <Comment><![CDATA[Estop routine to handle drives stopping]]></Comment>
      <Text><![CDATA[XIC(I_Estop_NOT_OK)XIO(Estop_Complete)OTL(Estop_IP);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Add the stop command below for each axis in the system for estop handling]]></Comment>
      <Text><![CDATA[XIC(Estop_IP)ONS(Oneshot_Estop)[RES(Timer_Power_Cycle) ,MAS(drvTransferLinear,Axis_TransferLinear_MAS_Estop,All,Yes,80,% of Maximum,No,1,% of Maximum) ,MAS(drvTransferRotary,Axis_TransferRotary_MAS_Estop,All,Yes,80,% of Maximum,No,1,% of Maximum) ,MAS(drvCanInsert,Axis_CanInsert_MAS_Estop,All,Yes,80,% of Maximum,No,1,% of Maximum) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(Estop_IP)[TON(Timer_Estop_Contact,?,?) ,[XIC(Axis_CanInsert_MAS_Estop.PC) XIC(Axis_TransferLinear_MAS_Estop.PC) XIC(Axis_TransferRotary_MAS_Estop.PC) ,XIC(Timer_Estop_Contact.DN) ] [OTL(Estop_Complete) ,OTU(Estop_IP) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIO(I_Estop_NOT_OK)XIC(Estop_Complete)OTU(Estop_Complete);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIO(I_Estop_NOT_OK)XIC(Permissive_Interlocks_OK)XIO(Estop_Complete)[OTE(O_Servos_Drive_Enable) ,TON(Timer_Enable_Delay,?,?) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(O_Servos_Drive_Enable)XIO(Estop_IP)XIO(Estop_Complete)XIC(Timer_Enable_Delay.DN)OTE(Enable_Drives_Requested);]]></Text>
    </Rung>
  </RLLContent>
</Routine>