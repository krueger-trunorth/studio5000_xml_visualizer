<?xml version="1.0" encoding="utf-8"?>
<Routine Name="rtBarcodeScannerSR751" Type="RLL">
  <Description><![CDATA[Main]]></Description>
  <RLLContent>
    <Rung Type="N">
      <Comment><![CDATA[Get data from the barcode reader]]></Comment>
      <Text><![CDATA[COP(SR751_Barcode_Reader:I,bcDataToPLC,124);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[[XIC(bitReadBarCodeRequest) ,XIC(Barcode.Initialize) ]EQU(intBarCodeStep,0)[COP(K_Str_Blank,strBarCode,1) ,MOV(10,intBarCodeStep) ,OTU(bitReadBarCodeRequest) ,OTU(bitBarCodeReadSucc) ,OTU(bitBarCodeTimedOut) ,OTU(Barcode.Initialize) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(intBarCodeStep,10)[OTL(bcDataFromPLC.bitReadRequest) ,TON(tmrBarCodeTimeout,?,?) ,XIC(bcDataToPLC.bitReadComplete) [OTU(bcDataFromPLC.bitReadRequest) ,MOV(20,intBarCodeStep) ] ,XIC(tmrBarCodeTimeout.DN) [OTL(bitBarCodeTimedOut) ,OTU(bcDataFromPLC.bitReadRequest) ,MOV(30,intBarCodeStep) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(intBarCodeStep,20)[SWPB(bcDataToPLC.strResultData.LEN,WORD,bcDataToPLC.strResultData.LEN) ,XIO(bcDataToPLC.bitReadFalure) [COP(bcDataToPLC.strResultData,strBarCode,1) ,OTL(bitBarCodeReadSucc) ] ,MOV(30,intBarCodeStep) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(intBarCodeStep,30)[[TON(tmrAntiRaceCond,?,?) ,OTU(bcDataFromPLC.bitReadCompleteClear) ] ,XIC(tmrAntiRaceCond.DN) [OTL(bcDataFromPLC.bitReadCompleteClear) ,XIO(bcDataToPLC.bitReadComplete) [OTU(bcDataFromPLC.bitReadCompleteClear) ,XIO(bitBarCodeReadSucc) OTL(bitBarCodeTimedOut) ,MOV(0,intBarCodeStep) ] ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Send commands to the barcode reader]]></Comment>
      <Text><![CDATA[COP(bcDataFromPLC,SR751_Barcode_Reader:O,124);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[GRT(strBarCode.LEN,12)MOV(12,strBarCode.LEN);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[GRT(strBarCode.LEN,0)MID(strBarCode,8,1,Barcode.Returned_String);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Map Barcode Bits and Data into existing variables]]></Comment>
      <Text><![CDATA[XIC(bitBarCodeReadSucc)OTE(Barcode.Complete);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(bitBarCodeTimedOut)OTE(Barcode.Faulted);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(Barcode.Reset_Faults)OTU(bitBarCodeTimedOut);]]></Text>
    </Rung>
  </RLLContent>
</Routine>