<?xml version="1.0" encoding="utf-8"?>
<Routine Name="sub01_Login" Type="RLL">
  <RLLContent>
    <Rung Type="N">
      <Comment><![CDATA[Wait for login to either fail or succeed.
]]></Comment>
      <Text><![CDATA[EQU(Pia.To_State,1010)[EQU(Pia.From_State,1510) NEQ(Pia.FROM_PIA.User_ID,k_blank_string) NEQ(Pia.FROM_PIA.Access_Level,k_blank_dint) MOV(1070,Pia.To_State) ,EQU(Pia.From_State,1570) [MOV(Pia.To_State,Pia.Machine.Alarm_Mc_State) ,MOV(Pia.From_State,Pia.Machine.Alarm_Pia_State) ,MOV(1160,Pia.To_State) ,MOV(1,Pia.Machine.Alarm_Message_Trigger) ,COP(k_pia_alarm_messages[Pia.Machine.Alarm_Message_Trigger],Pia.Machine.Alarm_Message,1) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[********************************* RETURN TO IDLE *********************************]]></Comment>
      <Text><![CDATA[NOP();]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[[EQU(Pia.To_State,1070) ,EQU(Pia.To_State,1160) ]EQU(Pia.From_State,100)[MOV(100,Pia.To_State) ,MOV(0,Pia.Command) ];]]></Text>
    </Rung>
  </RLLContent>
</Routine>