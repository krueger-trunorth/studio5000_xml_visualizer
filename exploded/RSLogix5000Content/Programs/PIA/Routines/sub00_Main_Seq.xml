<?xml version="1.0" encoding="utf-8"?>
<Routine Name="sub00_Main_Seq" Type="RLL">
  <RLLContent>
    <Rung Type="N">
      <Comment><![CDATA[When PLC-PIA communications initialization is complete, if there is no user and no access level then proceed to the login sequence.
]]></Comment>
      <Text><![CDATA[EQU(Pia.To_State,100)EQU(Pia.From_State,100)[EQU(Pia.FROM_PIA.User_ID,k_blank_string) ,EQU(Pia.FROM_PIA.Access_Level,k_blank_dint) ]MOV(1010,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Re-Initialize
]]></Comment>
      <Text><![CDATA[EQU(Pia.Command,1)XIO(Pia.Machine.Trans_In_Process)XIO(Pia.Alarm)ONS(ons_mainseq_01)MOV(10,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[User authentication for setup data changes.
]]></Comment>
      <Text><![CDATA[EQU(Pia.Command,2)XIO(Pia.Machine.Trans_In_Process)XIO(Pia.Alarm)EQU(Pia.To_State,100)EQU(Pia.From_State,100)ONS(ons_mainseq_02)MOV(2010,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Send setup data to PIA.
]]></Comment>
      <Text><![CDATA[EQU(Pia.Command,3)XIO(Pia.Machine.Trans_In_Process)XIO(Pia.Alarm)EQU(Pia.To_State,100)EQU(Pia.From_State,100)ONS(ons_mainseq_03)MOV(2100,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Case: MC initiates mtrl arrive + PIA read T#
]]></Comment>
      <Text><![CDATA[EQU(Pia.Command,4)XIO(Pia.Machine.Trans_In_Process)XIO(Pia.Alarm)EQU(Pia.To_State,100)EQU(Pia.From_State,100)ONS(ons_mainseq_04)MOV(3010,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Case: MC initiates mtrl arrive after reading T#
]]></Comment>
      <Text><![CDATA[EQU(Pia.Command,5)XIO(Pia.Machine.Trans_In_Process)XIO(Pia.Alarm)EQU(Pia.To_State,100)EQU(Pia.From_State,100)ONS(ons_mainseq_05)MOV(3190,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Case: Assembly started after pre-process check passed. This applies to both serial and lot T #.
]]></Comment>
      <Text><![CDATA[EQU(Pia.Command,6)XIO(Pia.Machine.Trans_In_Process)XIO(Pia.Alarm)EQU(Pia.To_State,100)EQU(Pia.From_State,100)ONS(ons_mainseq_06)MOV(5010,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Case: Assembly NOT started even though pre-process check passed. Operator triggers this event from MC HMI. (Example Reasons: Operator realizes Setup data was not updated and chooses to halt assembly, recipe on machine needs to be manually changed, etc.)
]]></Comment>
      <Text><![CDATA[EQU(Pia.Command,7)XIO(Pia.Machine.Trans_In_Process)XIO(Pia.Alarm)EQU(Pia.To_State,100)EQU(Pia.From_State,100)ONS(ons_mainseq_07)MOV(5040,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Case: Assembly process is stopped. MC Retains Trav # and can resume processing (i.e. mat'l arrived) This is different from close assembly. This state specifically applies to the Leads packaging machine when assembly is stopped to allow replenishment of a component.  No signoff is expected to be perfomrmed even though processing has started.
]]></Comment>
      <Text><![CDATA[EQU(Pia.Command,8)XIO(Pia.Machine.Trans_In_Process)XIO(Pia.Alarm)EQU(Pia.To_State,100)EQU(Pia.From_State,100)ONS(ons_mainseq_08)MOV(5070,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Case: Part within lot passed

]]></Comment>
      <Text><![CDATA[EQU(Pia.Command,9)XIO(Pia.Machine.Trans_In_Process)XIO(Pia.Alarm)EQU(Pia.To_State,100)EQU(Pia.From_State,100)ONS(ons_mainseq_09)MOV(6010,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Case: Part within lot failed
]]></Comment>
      <Text><![CDATA[EQU(Pia.Command,10)XIO(Pia.Machine.Trans_In_Process)XIO(Pia.Alarm)EQU(Pia.To_State,100)EQU(Pia.From_State,100)ONS(ons_mainseq_10)MOV(6020,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Case: Lot + MC reads T#
]]></Comment>
      <Text><![CDATA[EQU(Pia.Command,11)XIO(Pia.Machine.Trans_In_Process)XIO(Pia.Alarm)EQU(Pia.To_State,100)EQU(Pia.From_State,100)ONS(ons_mainseq_11)MOV(7010,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Case: Lot + PIA reads T#
]]></Comment>
      <Text><![CDATA[EQU(Pia.Command,12)XIO(Pia.Machine.Trans_In_Process)XIO(Pia.Alarm)EQU(Pia.To_State,100)EQU(Pia.From_State,100)ONS(ons_mainseq_12)MOV(7160,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Case: Serial + MC reads T#
]]></Comment>
      <Text><![CDATA[EQU(Pia.Command,13)XIO(Pia.Machine.Trans_In_Process)XIO(Pia.Alarm)EQU(Pia.To_State,100)EQU(Pia.From_State,100)ONS(ons_mainseq_13)MOV(7340,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Case: Serial + PIA reads T#
]]></Comment>
      <Text><![CDATA[EQU(Pia.Command,14)XIO(Pia.Machine.Trans_In_Process)XIO(Pia.Alarm)EQU(Pia.To_State,100)EQU(Pia.From_State,100)ONS(ons_mainseq_14)MOV(7490,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Case: ATLAS Laser Mark Rear Seal Step
]]></Comment>
      <Text><![CDATA[EQU(Pia.Command,15)XIO(Pia.Machine.Trans_In_Process)XIO(Pia.Alarm)EQU(Pia.To_State,100)EQU(Pia.From_State,100)ONS(ons_mainseq_15)MOV(10200,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Case: Machine issues logout
]]></Comment>
      <Text><![CDATA[EQU(Pia.Command,16)XIO(Pia.Machine.Trans_In_Process)XIO(Pia.Alarm)EQU(Pia.To_State,100)EQU(Pia.From_State,100)ONS(ons_mainseq_17)MOV(1390,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[[GRT(Pia.To_State,100) ONS(ons_main_09) ,XIC(Pia.Machine.Trans_In_Process) GRT(Pia.To_State,100) ]OTE(Pia.Machine.Trans_In_Process);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(Pia.Alarm)MOV(0,Pia.Command);]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[XIC(S:FS)[OTU(Pia.Machine.Signoff_Complete) ,OTU(Pia.Machine.PPC_Complete) ,OTU(Pia.Machine.Setup_Complete) ,OTU(Pia.Machine.SOB_Complete) ,OTU(Pia.Machine.MatlArrived_Complete) ,OTU(Pia.Machine.CloseAssy_Complete) ,OTU(Pia.Machine.PPC_Fail) ,OTU(Pia.Machine.PPC_Pass) ,OTU(Pia.Machine.Signoff_Pass) ,OTU(Pia.Machine.Signoff_Fail) ,OTU(Pia.Machine.Signoff_Rwk_Pass) ,OTU(Pia.Trig.Wait_For_PIA) ];]]></Text>
    </Rung>
  </RLLContent>
</Routine>