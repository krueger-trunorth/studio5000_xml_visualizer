<?xml version="1.0" encoding="utf-8"?>
<Routine Name="sub00_Init" Type="RLL">
  <RLLContent>
    <Rung Type="N">
      <Comment><![CDATA[Check for PIA response to PLC initialization command.  If expected response not received then zero the TO_STATE then re-command initialization command from PLC.
]]></Comment>
      <Text><![CDATA[[EQU(Pia.To_State,10) NEQ(Pia.From_State,11) TON(init_resp_wait,?,?) ,[XIC(init_resp_wait.DN) ,XIC(init_resp_wait2.TT) ] [MOV(0,Pia.To_State) ,TON(init_resp_wait2,?,?) ,XIC(init_resp_wait2.DN) [MOV(10,Pia.To_State) ,RES(init_resp_wait) RES(init_resp_wait2) ] ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Wait for the PIA app to respond to an initialization request before moving on.
]]></Comment>
      <Text><![CDATA[EQU(Pia.To_State,10)EQU(Pia.From_State,11)[MOV(50,Pia.To_State) ,CPS(k_blank_pia.TO_PIA,Pia.TO_PIA,1) ,CPS(k_blank_pia.FROM_PIA,Pia.FROM_PIA,1) ,CPS(k_blank_pia.Trig,Pia.Trig,1) ,MOV(0,Pia.Machine.Alarm_Mc_State) ,MOV(0,Pia.Machine.Alarm_Pia_State) ,COP(k_blank_string,initialized_PC_ID,1) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Wait for the PC ID to be sent from PIA.

]]></Comment>
      <Text><![CDATA[EQU(Pia.To_State,50)NEQ(Pia.FROM_PIA.PC_ID,k_blank_string)MID(Pia.FROM_PIA.PC_ID,1,1,Pia_FromPia_PC_ID_Char1)NEQ(Pia_FromPia_PC_ID_Char1,InValid_PC_ID)[TON(init_pc_id_dly_tmr,?,?) ,XIC(init_pc_id_dly_tmr.DN) [MOV(60,Pia.To_State) ,COP(Pia.FROM_PIA.PC_ID,initialized_PC_ID,1) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Wait for the PC ID to be cleared from PIA.

]]></Comment>
      <Text><![CDATA[EQU(Pia.To_State,60)EQU(Pia.FROM_PIA.PC_ID,k_blank_string)MOV(80,Pia.To_State);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Wait for the PIA app to go to the IDLE state.
Initialization is complete.
]]></Comment>
      <Text><![CDATA[EQU(Pia.To_State,80)EQU(Pia.From_State,100)[MOV(100,Pia.To_State) ,OTL(Pia.Machine.Initialized) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[When the PIA app is re-started clear out all PIA data registers in the PLC and begin the initialization.

PIA app is restarted via a trigger or by going to a specific state.
]]></Comment>
      <Text><![CDATA[[XIC(Pia.Trig.Restart_Rqst) ,EQU(Pia.From_State,10) ][MOV(10,Pia.To_State) ,OTU(Pia.Machine.Initialized) ,OTU(Pia.Trig.Restart_Rqst) ];]]></Text>
    </Rung>
  </RLLContent>
</Routine>