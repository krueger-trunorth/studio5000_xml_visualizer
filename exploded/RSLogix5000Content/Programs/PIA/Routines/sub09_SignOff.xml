      <Text><![CDATA[EQU(Pia.To_State,100)EQU(Pia.From_State,100)EQU(Pia.Machine.Alarm_Mc_State,0)EQU(Pia.Machine.Alarm_Pia_State,0)XIC(Pia.Trig.SignRwkPass_Rqst)[XIC(debug_mode) XIC(debug_next_step) ,XIO(debug_mode) ][MOV(9190,Pia.To_State) ,OTU(Pia.Trig.SignRwkPass_Rqst) ,OTU(debug_next_step) ];]]></Text>
