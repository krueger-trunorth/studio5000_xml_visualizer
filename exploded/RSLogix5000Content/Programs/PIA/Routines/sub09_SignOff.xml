      <Text><![CDATA[[EQU(Pia.To_State,9015) ,EQU(Pia.To_State,9100) ,EQU(Pia.To_State,9120) ,EQU(Pia.To_State,9160) ,EQU(Pia.To_State,9200) ,EQU(Pia.To_State,9400) ,EQU(Pia.To_State,9420) ,EQU(Pia.To_State,9460) ]EQU(Pia.From_State,100)[MOV(100,Pia.To_State) ,MOV(0,Pia.Command) ,OTE(signoff_complete) ,OTU(Pia.Machine.CloseAssy_Complete) ,OTU(Pia.Machine.SOB_Complete) ];]]></Text>
