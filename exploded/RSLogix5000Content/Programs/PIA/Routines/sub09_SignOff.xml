<Routine Name="sub09_SignOff" Type="RLL">
  <RLLContent>
    <Rung Type="N">
      <Comment><![CDATA[Case: Signoff pass
]]></Comment>
      <Text><![CDATA[NOP();]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(Pia.To_State,100)EQU(Pia.From_State,100)EQU(Pia.Machine.Alarm_Mc_State,0)EQU(Pia.Machine.Alarm_Pia_State,0)XIC(Pia.Trig.SignPass_Rqst)[XIC(debug_mode) XIC(debug_next_step) ,XIO(debug_mode) ][MOV(9010,Pia.To_State) ,OTU(Pia.Trig.SignPass_Rqst) ,OTU(debug_next_step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(Pia.To_State,9010)EQU(Pia.From_State,9520)[XIC(debug_mode) XIC(debug_next_step) ,XIO(debug_mode) ][OTL(Pia.Machine.Signoff_Pass) ,OTU(Pia.Machine.Signoff_Fail) ,OTU(Pia.Machine.Signoff_Rwk_Pass) ,MOV(9015,Pia.To_State) OTU(debug_next_step) ];]]></Text>
    </Rung>
    <Rung Type="N">
