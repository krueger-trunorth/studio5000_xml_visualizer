]]></Comment>
      <Text><![CDATA[NOP();]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(Pia.To_State,100)EQU(Pia.From_State,100)EQU(Pia.Machine.Alarm_Mc_State,0)EQU(Pia.Machine.Alarm_Pia_State,0)XIC(Pia.Trig.SignFail_Rqst)[XIC(debug_mode) XIC(debug_next_step) ,XIO(debug_mode) ][MOV(9040,Pia.To_State) ,OTU(Pia.Trig.SignFail_Rqst) ,OTU(debug_next_step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(Pia.To_State,9040)EQU(Pia.From_State,9540)[XIC(debug_mode) XIC(debug_next_step) ,XIO(debug_mode) ][MOV(9070,Pia.To_State) ,OTL(Pia.Machine.Signoff_Fail) ,OTU(Pia.Machine.Signoff_Pass) ,OTU(Pia.Machine.Signoff_Rwk_Pass) ,OTU(debug_next_step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(Pia.To_State,9070)[XIC(debug_mode) XIC(debug_next_step) ,XIO(debug_mode) ]EQU(Pia.From_State,9570)[MOV(9100,Pia.To_State) ,OTU(debug_next_step) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Case: Signoff pass with MATT rework record
]]></Comment>
      <Text><![CDATA[NOP();]]></Text>
    </Rung>
