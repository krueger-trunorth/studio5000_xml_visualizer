<?xml version="1.0" encoding="utf-8"?>
<Routine Name="sub00_Main" Type="RLL">
  <RLLContent>
    <Rung Type="N">
      <Text><![CDATA[SIZE(Pia.Machine.Trav_Numbers[0],0,trav_number_array_size);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Move the heartbeat timer to the tag which PIA will read so that PIA knows what the period is for which the PLC will wait before generating a communications tme-out condition.
]]></Comment>
      <Text><![CDATA[MOV(2500,Pia.TO_PIA.Heartbeat_Time);]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Heartbeat timer.
]]></Comment>
      <Text><![CDATA[[MUL(Pia.TO_PIA.Heartbeat_Time,10,hb_from_tmr.PRE) ,GEQ(hb_max_reset,hb_from_tmr.PRE) MOV(0,hb_max_reset) ,GEQ(Pia.To_State,100) TON(hb_from_tmr,?,?) ,GRT(hb_from_tmr.ACC,hb_max_reset) MOV(hb_from_tmr.ACC,hb_max_reset) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Reset the heartbeat timer.
]]></Comment>
      <Text><![CDATA[GRT(Pia.To_State,50)[[NEQ(Pia.FROM_PIA.PC_ID,k_blank_string) ONS(ons_main_01) RES(hb_from_tmr) ,EQU(Pia.FROM_PIA.PC_ID,k_blank_string) ONS(ons_main_02) RES(hb_from_tmr) ] XIO(pc_id_hb_timer_reset) OTE(pc_id_hb_timer_reset) ,[XIC(pc_id_hb_timer_reset) ,XIC(pc_id_hb_delay_timer.TT) ] [MOV(Pia.TO_PIA.Heartbeat_Time,pc_id_hb_delay_timer.PRE) ,TON(pc_id_hb_delay_timer,?,?) ,XIC(pc_id_hb_delay_timer.DN) COP(Pia.FROM_PIA.PC_ID,Pia.TO_PIA.PC_ID,1) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[GRT(Pia.To_State,50)NEQ(Pia.FROM_PIA.PC_ID,k_blank_string)MID(Pia.FROM_PIA.PC_ID,1,1,Pia_FromPia_PC_ID_Char1)NEQ(Pia_FromPia_PC_ID_Char1,InValid_PC_ID)NEQ(Pia.FROM_PIA.PC_ID,initialized_PC_ID)[TON(pc_id_check_timer,?,?) ,XIC(pc_id_check_timer.DN) [MOV(38,Pia.Machine.Alarm_Message_Trigger) ,CONCAT(k_pia_alarm_messages[Pia.Machine.Alarm_Message_Trigger],initialized_PC_ID,Pia.Machine.Alarm_Message) ,CONCAT(Pia.Machine.Alarm_Message,k_pc_conflict_msg_2,Pia.Machine.Alarm_Message) ,CONCAT(Pia.Machine.Alarm_Message,Pia.FROM_PIA.PC_ID,Pia.Machine.Alarm_Message) ,COP(k_blank_string,Pia.FROM_PIA.PC_ID,1) ] ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[On the first scan:
Command initialization and clear out all pertinent data registers.
]]></Comment>
      <Text><![CDATA[XIC(S:FS)[MOV(10,Pia.To_State) ,MOV(0,Pia.Machine.Alarm_Mc_State) ,MOV(0,Pia.Machine.Alarm_Pia_State) ,COP(k_blank_string,Pia.FROM_PIA.User_ID,1) ,MOV(k_blank_dint,Pia.FROM_PIA.Access_Level) ,OTU(Pia.Machine.Initialized) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Communications error detected by loss of heartbeat.

Reinitialize after loss.
]]></Comment>
      <Text><![CDATA[GEQ(Pia.To_State,100)XIC(hb_from_tmr.DN)[OTU(Pia.Machine.Initialized) ,MOV(10,Pia.To_State) ,MOV(37,Pia.Machine.Alarm_Message_Trigger) ,COP(k_pia_alarm_messages[Pia.Machine.Alarm_Message_Trigger],Pia.Machine.Alarm_Message,1) ,RES(hb_from_tmr) ,ADD(hb_failures,1,hb_failures) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Text><![CDATA[EQU(Pia.To_State,-1)ONS(ons_main_03)[MOV(-1,Pia.Machine.Alarm_Mc_State) ,MOV(-1,Pia.Machine.Alarm_Pia_State) ,MOV(5,Pia.Machine.Alarm_Message_Trigger) ,COP(k_pia_alarm_messages[Pia.Machine.Alarm_Message_Trigger],Pia.Machine.Alarm_Message,1) ];]]></Text>
    </Rung>
    <Rung Type="N">
      <Comment><![CDATA[Clear all PIA alarms.
]]></Comment>
      <Text><![CDATA[XIC(Pia.Machine.Alarm_Clear_All_PB)XIC(Pia.Alarm)[MOV(0,Pia.Machine.Alarm_Pia_State) MOV(0,Pia.Machine.Alarm_Mc_State) ,MOV(k_blank_dint,Pia.Machine.Alarm_Message_Trigger) ,COP(k_blank_string_array[0],Pia.Machine.Alarm_Message,1) ,OTU(Pia.Machine.Alarm_Clear_All_PB) ,OTU(Pia.Machine.Signoff_Complete) ,OTU(Pia.Machine.Setup_Complete) ,OTU(Pia.Machine.PPC_Complete) ,OTU(Pia.Machine.SOB_Complete) ,OTU(Pia.Machine.MatlArrived_Complete) ,OTU(Pia.Machine.CloseAssy_Complete) ];]]></Text>
    </Rung>
  </RLLContent>
</Routine>