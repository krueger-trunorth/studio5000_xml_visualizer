<?xml version="1.0" encoding="utf-8"?>
<DataType Name="ORT_Vision_Camera_Requests" Family="NoFamily" Class="User">
  <Description><![CDATA[Camera requests from the PLC to the vision System]]></Description>
  <Members>
    <Member Name="iCalibrate" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
      <Description><![CDATA[Perform a calibration in an inspection]]></Description>
    </Member>
    <Member Name="iUpdateCalibration" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
      <Description><![CDATA[Update calibration in this tool and disperse to other tools]]></Description>
    </Member>
    <Member Name="iRun" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
      <Description><![CDATA[Run an inspection]]></Description>
    </Member>
    <Member Name="iRunContinuous" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
      <Description><![CDATA[Run an inspection continuously]]></Description>
    </Member>
    <Member Name="iHalt" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
      <Description><![CDATA[Halt an inspection in process]]></Description>
    </Member>
    <Member Name="iSaveLast" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
      <Description><![CDATA[Save the last image from an inspection]]></Description>
    </Member>
    <Member Name="iLive" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
      <Description><![CDATA[A request to display some vision job in live mode]]></Description>
    </Member>
    <Member Name="ZZZZZZZZZZORT_Vision7" DataType="SINT" Dimension="0" Radix="Decimal" Hidden="true" ExternalAccess="Read/Write" />
    <Member Name="bSave1" DataType="BIT" Dimension="0" Radix="Decimal" Hidden="false" Target="ZZZZZZZZZZORT_Vision7" BitNumber="0" ExternalAccess="Read/Write">
      <Description><![CDATA[Save the image after the current inspection finishes in save path 1]]></Description>
    </Member>
    <Member Name="bSave2" DataType="BIT" Dimension="0" Radix="Decimal" Hidden="false" Target="ZZZZZZZZZZORT_Vision7" BitNumber="1" ExternalAccess="Read/Write">
      <Description><![CDATA[Save the raw image after the current inspection finishes in save path 2]]></Description>
    </Member>
    <Member Name="bCompute13ngulation" DataType="BIT" Dimension="0" Radix="Decimal" Hidden="false" Target="ZZZZZZZZZZORT_Vision7" BitNumber="2" ExternalAccess="Read/Write">
      <Description><![CDATA[Do an N-point calibration with data in the CalibrationData field]]></Description>
    </Member>
    <Member Name="Inputs" DataType="ORT_Vision_Camera_Inputs" Dimension="0" Radix="NullType" Hidden="false" ExternalAccess="Read/Write">
      <Description><![CDATA[Inspection inputs]]></Description>
    </Member>
  </Members>
</DataType>