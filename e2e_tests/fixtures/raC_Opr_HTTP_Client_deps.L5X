<EncodedData EncodedType="AddOnInstructionDefinition" Name="raC_Tec_ByteArrToString" Revision="1.0" Vendor="Rockwell Automation" EditedDate="2023-03-17T13:13:19.834Z" SoftwareRevision="v34.00" EncryptionConfig="9">
<Description>
<![CDATA[Convert an Array of Bytes into a string.
Supports decimal(0) and Hex in lower(1) or upper(2) case.]]>
</Description>
<RevisionNote>
<![CDATA[Release]]>
</RevisionNote>
<Parameters>
<Parameter Name="EnableIn" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
