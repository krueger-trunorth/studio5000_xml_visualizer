<Description>
<![CDATA[Ascii Code of seperator.
32 = [SPACE]
46 = [.]
58 = [:]
95 = [_]
etc.]]>
</Description>
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="SINT" Radix="Decimal" Value="0"/>
</DefaultData>
